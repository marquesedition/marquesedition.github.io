---
interface Reel {
  url: string;
  date: string;
  title: string;
  summary: string;
  label: string;
}

interface Props {
  reel: Reel;
  index: number;
  isHero?: boolean;
}

const { reel, index, isHero = false } = Astro.props;

const formatDisplayDate = (dateValue: string) => {
  const date = new Date(`${dateValue}T12:00:00`);
  return new Intl.DateTimeFormat("es-ES", {
    day: "numeric",
    month: "short",
    year: "numeric",
  }).format(date);
};
---

<article class:list={["reel-card", isHero && "reel-card--hero"]}>
  <div class="reel-topline">
    <span class="reel-rank">#{index}</span>
    <span class="reel-flag">{isHero ? "Último reel" : "Reel"}</span>
  </div>
  <h3>{reel.title}</h3>
  <p class="reel-meta">{formatDisplayDate(reel.date)} · {reel.label}</p>
  <p class="reel-desc">{reel.summary}</p>
  <div class="reel-embed">
    <blockquote
      class="instagram-media"
      data-instgrm-permalink={reel.url}
      data-instgrm-version="14"
      style="background:#120b31; border:0; margin:0; padding:0; width:100%;"
    >
      <a href={reel.url} target="_blank" rel="noopener noreferrer">Ver reel en Instagram</a>
    </blockquote>
  </div>
  <div class="reel-footer">
    <span class="reel-label">{reel.label}</span>
    <a class="reel-link" href={reel.url} target="_blank" rel="noopener noreferrer">Abrir reel ↗</a>
  </div>
</article>

<style>
  .reel-card {
    padding: 0.95rem;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04)),
      linear-gradient(155deg, rgba(42, 30, 95, 0.48), rgba(18, 12, 44, 0.72));
  }

  .reel-card--hero {
    border-color: rgba(255, 90, 191, 0.28);
    background:
      radial-gradient(360px 180px at 12% 8%, rgba(255, 90, 191, 0.18), transparent 72%),
      radial-gradient(320px 180px at 88% 10%, rgba(69, 215, 255, 0.16), transparent 74%),
      linear-gradient(155deg, rgba(58, 34, 118, 0.58), rgba(16, 11, 38, 0.88));
  }

  .reel-topline,
  .reel-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .reel-topline {
    margin-bottom: 0.65rem;
  }

  .reel-rank,
  .reel-label {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0.35rem 0.72rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: #f8fbff;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.03em;
  }

  .reel-rank {
    min-width: 2rem;
    justify-content: center;
  }

  .reel-flag {
    color: #f6f7ff;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.28;
  }

  .reel-meta {
    margin: 0.45rem 0 0;
    color: #c2cae2;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .reel-desc {
    margin: 0.55rem 0 0;
    color: #dde5fb;
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .reel-embed {
    margin-top: 0.8rem;
    min-height: 440px;
  }

  .reel-embed :global(.instagram-media) {
    width: 100% !important;
    min-width: 100% !important;
    max-width: 100% !important;
    margin: 0 !important;
    border-radius: 18px !important;
  }

  .reel-footer {
    margin-top: 0.8rem;
  }

  .reel-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(69, 215, 255, 0.28);
    background: rgba(69, 215, 255, 0.08);
    color: var(--blue);
    font-size: 0.82rem;
    font-weight: 800;
    text-decoration: none;
  }
</style>
