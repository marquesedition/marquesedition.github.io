---
import { Image } from "astro:assets";
import logoImage from "../../assets/logo.png";
import profileImage from "../../assets/profile.png";
import SiteLayout from "../../layouts/SiteLayout.astro";
import InnerPage from "../../components/layout/InnerPage.astro";
import Footer from "../../components/layout/Footer.astro";
import { getInnerPageNav } from "../../config/navigation";

const navItems = getInnerPageNav("/sets/");

const setTitle = "28.03.2026";
const setDuration = "14:47";
const setSourceUrl = "https://drive.google.com/file/d/11WJX9qz5xcq72cVl4yHRI6JAE6CMFXzx/view?usp=sharing";
const setAudioUrl = "/audio/set-2026-03-28.mp3";
---

<SiteLayout
  title="Marques Edition | Sets"
  description="Sets de Marques Edition dentro de la web. Escucha sesiones largas con reproductor integrado sin salir del sitio."
>
  <InnerPage
    ariaLabel="Sets de Marques Edition"
    eyebrow="Sets"
    title="Aquí puedes escuchar mis sets largos dentro de la web."
    description="Esta sección queda separada de remixes y reels. Aquí van las sesiones largas con reproductor integrado para escuchar el set directamente desde la web."
    navItems={navItems}
  >
    <Fragment slot="main">
      <section class="section" aria-labelledby="sets-title">
        <p class="section-kicker">Set cargado</p>
        <h2 id="sets-title">Primera sesión larga publicada</h2>
        <p class="section-copy">
          Aquí no van remixes sueltos ni edits cortos. Esta ruta queda reservada para sets
          completos, con escucha directa dentro de la web y separado del resto del contenido.
        </p>

        <article class="set-card" aria-label={`Set ${setTitle}`}>
          <div class="set-topline">
            <span class="set-chip">Set #1</span>
            <span class="set-chip">Duración {setDuration}</span>
          </div>

          <div class="set-body">
            <Image
              src={profileImage}
              alt="Imagen de Marques Edition"
              loading="lazy"
              sizes="(max-width: 719px) 100vw, 168px"
            />

            <div class="set-copy">
              <h3>{setTitle}</h3>
              <p class="set-meta">Set largo · audio MP3 · Google Drive</p>
              <p class="set-text">
                Primera sesión reproducible dentro de la web. Esta página queda lista para ir
                sumando nuevos sets completos sin mezclarlos con la ruta de remixes.
              </p>
            </div>
          </div>

          <div class="player-box">
            <div class="custom-player" data-audio-player>
              <audio class="audio-player-native" preload="metadata" src={setAudioUrl}>
                Tu navegador no soporta audio HTML5. Puedes abrir el archivo original en Google Drive.
              </audio>

              <div class="player-meta-row">
                <button class="player-toggle" type="button" data-player-toggle aria-label="Reproducir set">
                  <span class="player-toggle-icon" aria-hidden="true">Play</span>
                </button>

                <div class="player-title-wrap">
                  <strong>Marques Edition</strong>
                  <span>Set largo · {setTitle}</span>
                </div>

                <button class="player-mute" type="button" data-player-mute aria-label="Silenciar set">
                  Vol
                </button>
              </div>

              <div
                class="waveform-shell"
                data-waveform-hit
                role="button"
                tabindex="0"
                aria-label="Mover reproducción del set"
              >
                <div class="waveform-overlay">
                <div class="waveform-avatar">
                    <Image src={logoImage} alt="" loading="lazy" />
                  </div>
                  <div class="waveform-tag">
                    <strong>Marques Edition</strong>
                    <span>Waveform del set</span>
                  </div>
                </div>

                <canvas class="waveform-canvas" data-waveform-canvas aria-hidden="true"></canvas>
                <div class="waveform-playhead" data-waveform-playhead></div>
              </div>

              <div class="player-time-row" aria-hidden="true">
                <span data-player-current>0:00</span>
                <span data-player-duration>{setDuration}</span>
              </div>
            </div>
          </div>

          <div class="set-actions">
            <a class="side-link" href={setSourceUrl} target="_blank" rel="noopener noreferrer">Abrir archivo original ↗</a>
          </div>
        </article>
      </section>
    </Fragment>

    <Fragment slot="sidebar">
      <section class="side-card" aria-labelledby="reason-title">
        <p class="side-kicker">Por qué separado</p>
        <h2 id="reason-title">Remixes y sets no enseñan lo mismo</h2>
        <p>
          Los remixes enseñan edición, gusto y color musical. Los sets largos enseñan narrativa,
          transición, selección y aguante de pista. Por eso van en rutas distintas.
        </p>
      </section>

      <section class="side-card" aria-labelledby="set-info-title">
        <p class="side-kicker">Este archivo</p>
        <h2 id="set-info-title">Datos rápidos del set</h2>
        <div class="coming-grid" aria-label="Datos del set">
          <div class="coming-card">
            <strong>Fecha</strong>
            <span>{setTitle}</span>
          </div>
          <div class="coming-card">
            <strong>Duración</strong>
            <span>{setDuration}</span>
          </div>
          <div class="coming-card">
            <strong>Fuente</strong>
            <span>Google Drive</span>
          </div>
        </div>
      </section>

      <section class="side-card" aria-labelledby="next-title">
        <p class="side-kicker">Cruce rápido</p>
        <h2 id="next-title">Dónde ver el resto del proyecto</h2>
        <div class="side-stack">
          <a class="side-link" href="/streams/">Ver remixes ↗</a>
          <a class="side-link" href="/reels/">Ver reels ↗</a>
          <a class="side-link" href="/booking/">Ir a booking ↗</a>
        </div>
      </section>
    </Fragment>

    <Footer slot="footer" />
  </InnerPage>

  <style>
    .coming-grid,
    .side-stack {
      display: grid;
      gap: 0.7rem;
    }

    .coming-grid,
    .set-actions {
      margin-top: 0.9rem;
    }

    .coming-card,
    .set-card,
    .player-box {
      padding: 0.95rem;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.05);
    }

    .set-card {
      margin-top: 0.9rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
        linear-gradient(160deg, rgba(90, 70, 180, 0.12), rgba(18, 12, 50, 0.16));
    }

    .set-topline,
    .set-actions {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.65rem;
      flex-wrap: wrap;
    }

    .set-chip {
      display: inline-flex;
      align-items: center;
      min-height: 32px;
      padding: 0.4rem 0.74rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      color: #fff;
      font-size: 0.76rem;
      font-weight: 800;
    }

    .set-body {
      margin-top: 0.9rem;
      display: grid;
      gap: 0.9rem;
    }

    .set-body img {
      width: 100%;
      aspect-ratio: 1 / 1;
      object-fit: cover;
      object-position: center 20%;
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .set-copy h3 {
      margin: 0;
      font-size: 1rem;
      line-height: 1.28;
    }

    .set-meta,
    .set-text {
      margin: 0.42rem 0 0;
      color: var(--muted-strong);
      font-size: 0.84rem;
      line-height: 1.5;
    }

    .set-text {
      font-size: 0.88rem;
    }

    .player-box {
      margin-top: 0.9rem;
    }

    .custom-player {
      display: grid;
      gap: 0.8rem;
    }

    .audio-player-native {
      display: none;
    }

    .player-meta-row {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.75rem;
      align-items: center;
    }

    .player-toggle,
    .player-mute {
      min-height: 44px;
      border: 0;
      border-radius: 999px;
      background:
        linear-gradient(135deg, rgba(255, 90, 191, 0.92), rgba(69, 215, 255, 0.88));
      color: #13082f;
      font-size: 0.78rem;
      font-weight: 900;
      cursor: pointer;
      transition:
        transform 160ms ease,
        box-shadow 160ms ease,
        opacity 160ms ease;
    }

    .player-toggle {
      min-width: 88px;
      padding: 0.7rem 1rem;
    }

    .player-title-wrap {
      min-width: 0;
      display: grid;
      gap: 0.14rem;
    }

    .player-title-wrap strong,
    .player-title-wrap span {
      display: block;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .player-title-wrap strong {
      font-size: 0.92rem;
      line-height: 1.2;
    }

    .player-title-wrap span {
      color: var(--muted-strong);
      font-size: 0.76rem;
      font-weight: 700;
    }

    .player-mute {
      min-width: 60px;
      padding: 0.7rem 0.9rem;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04)),
        rgba(255, 255, 255, 0.06);
      color: #f7f3ff;
    }

    .player-toggle:hover,
    .player-toggle:focus-visible,
    .player-mute:hover,
    .player-mute:focus-visible {
      transform: translateY(-1px);
      box-shadow: 0 12px 24px rgba(8, 3, 25, 0.34);
      outline: none;
    }

    .player-time-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      color: var(--muted-strong);
      font-size: 0.76rem;
      font-weight: 800;
    }

    .waveform-shell {
      position: relative;
      display: block;
      width: 100%;
      padding: 0;
      border: 0;
      border-radius: 20px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
        linear-gradient(160deg, rgba(20, 13, 52, 0.96), rgba(8, 6, 23, 0.98));
      overflow: hidden;
      cursor: pointer;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
      outline: none;
    }

    .waveform-overlay {
      position: absolute;
      top: 0.85rem;
      left: 0.85rem;
      z-index: 2;
      display: flex;
      align-items: center;
      gap: 0.65rem;
      pointer-events: none;
    }

    .waveform-avatar {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.12);
      box-shadow: 0 10px 18px rgba(0, 0, 0, 0.24);
      background: rgba(255, 255, 255, 0.08);
    }

    .waveform-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .waveform-tag {
      display: grid;
      gap: 0.08rem;
      padding: 0.45rem 0.62rem;
      border-radius: 14px;
      background: rgba(7, 6, 20, 0.58);
      backdrop-filter: blur(12px);
      text-align: left;
    }

    .waveform-tag strong {
      font-size: 0.8rem;
      line-height: 1.15;
    }

    .waveform-tag span {
      color: var(--muted-strong);
      font-size: 0.7rem;
      font-weight: 700;
      line-height: 1.1;
    }

    .waveform-canvas {
      display: block;
      width: 100%;
      height: 132px;
    }

    .waveform-playhead {
      position: absolute;
      top: 0;
      bottom: 0;
      left: 0;
      width: 2px;
      background: rgba(255, 255, 255, 0.88);
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08);
      transform: translateX(-1px);
      pointer-events: none;
    }

    .coming-card strong {
      display: block;
      font-size: 0.95rem;
    }

    .coming-card span {
      display: block;
      margin-top: 0.24rem;
      color: var(--muted-strong);
      font-size: 0.82rem;
      line-height: 1.45;
    }

    .side-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 0.55rem 0.9rem;
      border-radius: 999px;
      border: 1px solid rgba(69, 215, 255, 0.28);
      background: rgba(69, 215, 255, 0.08);
      color: var(--blue);
      font-size: 0.82rem;
      font-weight: 800;
      text-decoration: none;
    }

    @media (min-width: 720px) {
      .set-body {
        grid-template-columns: 168px minmax(0, 1fr);
        align-items: start;
      }

      .set-body img {
        height: 168px;
      }
    }

    @media (max-width: 560px) {
      .player-meta-row {
        grid-template-columns: minmax(0, 1fr);
      }

      .player-toggle,
      .player-mute {
        width: 100%;
      }

      .waveform-shell,
      .waveform-canvas {
        min-height: 118px;
        height: 118px;
      }
    }
  </style>

  <script is:inline>
    const formatTime = (value) => {
      if (!Number.isFinite(value) || value < 0) return "0:00";
      const totalSeconds = Math.floor(value);
      const minutes = Math.floor(totalSeconds / 60);
      const seconds = totalSeconds % 60;
      return `${minutes}:${String(seconds).padStart(2, "0")}`;
    };

    const pauseOtherPlayers = (currentAudio) => {
      document.querySelectorAll("[data-audio-player] .audio-player-native").forEach((audio) => {
        if (audio !== currentAudio) audio.pause();
      });
    };

    document.querySelectorAll("[data-audio-player]").forEach((player) => {
      const audio = player.querySelector(".audio-player-native");
      const toggle = player.querySelector("[data-player-toggle]");
      const toggleIcon = player.querySelector(".player-toggle-icon");
      const mute = player.querySelector("[data-player-mute]");
      const waveformHit = player.querySelector("[data-waveform-hit]");
      const waveformCanvas = player.querySelector("[data-waveform-canvas]");
      const playhead = player.querySelector("[data-waveform-playhead]");
      const current = player.querySelector("[data-player-current]");
      const duration = player.querySelector("[data-player-duration]");
      const ctx = waveformCanvas.getContext("2d");
      let waveformPeaks = [];

      const generateFallbackPeaks = (count) =>
        Array.from({ length: count }, (_, index) => {
          const base = Math.sin(index * 0.56) * 0.24 + Math.sin(index * 0.11) * 0.18;
          return Math.max(0.18, 0.42 + base);
        });

      const drawWaveform = () => {
        const rect = waveformCanvas.getBoundingClientRect();
        const width = Math.max(1, Math.floor(rect.width));
        const height = Math.max(1, Math.floor(rect.height));
        const dpr = window.devicePixelRatio || 1;
        waveformCanvas.width = Math.floor(width * dpr);
        waveformCanvas.height = Math.floor(height * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.clearRect(0, 0, width, height);

        const peaks = waveformPeaks.length ? waveformPeaks : generateFallbackPeaks(Math.max(48, Math.floor(width / 6)));
        const progress = audio.duration ? audio.currentTime / audio.duration : 0;
        const barWidth = 3;
        const gap = 2;
        const totalBarWidth = barWidth + gap;
        const totalWidth = peaks.length * totalBarWidth;
        const offsetX = Math.max(0, (width - totalWidth + gap) / 2);
        const midY = height / 2;

        peaks.forEach((peak, index) => {
          const barHeight = Math.max(8, peak * (height * 0.66));
          const x = offsetX + index * totalBarWidth;
          const y = midY - barHeight / 2;
          const played = (x + barWidth) / width <= progress;

          ctx.fillStyle = played ? "rgba(255, 255, 255, 0.95)" : "rgba(111, 229, 255, 0.38)";
          ctx.fillRect(x, y, barWidth, barHeight);
        });

        if (playhead) {
          playhead.style.left = `${progress * 100}%`;
        }
      };

      const loadWaveform = async () => {
        try {
          const AudioContextCtor = window.AudioContext || window.webkitAudioContext;
          const audioContext = new AudioContextCtor();
          const response = await fetch(audio.currentSrc || audio.src);
          const arrayBuffer = await response.arrayBuffer();
          const buffer = await audioContext.decodeAudioData(arrayBuffer.slice(0));
          const channelData = buffer.getChannelData(0);
          const sampleCount = Math.max(60, Math.floor(waveformCanvas.getBoundingClientRect().width / 5));
          const blockSize = Math.floor(channelData.length / sampleCount);
          waveformPeaks = Array.from({ length: sampleCount }, (_, index) => {
            const start = index * blockSize;
            const end = Math.min(channelData.length, start + blockSize);
            let peak = 0;
            for (let i = start; i < end; i += 1) {
              const value = Math.abs(channelData[i]);
              if (value > peak) peak = value;
            }
            return Math.max(0.12, peak);
          });
          if (audioContext.state !== "closed") audioContext.close();
        } catch (error) {
          waveformPeaks = generateFallbackPeaks(72);
        }
        drawWaveform();
      };

      const updateProgress = () => {
        current.textContent = formatTime(audio.currentTime);
        drawWaveform();
      };

      const updateDuration = () => {
        if (Number.isFinite(audio.duration)) {
          duration.textContent = formatTime(audio.duration);
        }
      };

      const updateToggle = () => {
        const playing = !audio.paused;
        toggleIcon.textContent = playing ? "Pause" : "Play";
        toggle.setAttribute("aria-label", playing ? "Pausar set" : "Reproducir set");
      };

      const updateMute = () => {
        mute.textContent = audio.muted ? "Mute" : "Vol";
        mute.setAttribute("aria-label", audio.muted ? "Activar sonido" : "Silenciar set");
      };

      toggle.addEventListener("click", async () => {
        if (audio.paused) {
          pauseOtherPlayers(audio);
          await audio.play();
        } else {
          audio.pause();
        }
      });

      mute.addEventListener("click", () => {
        audio.muted = !audio.muted;
        updateMute();
      });

      waveformHit.addEventListener("click", (event) => {
        if (!audio.duration) return;
        const rect = waveformHit.getBoundingClientRect();
        const ratio = Math.min(1, Math.max(0, (event.clientX - rect.left) / rect.width));
        const nextTime = ratio * audio.duration;
        audio.currentTime = nextTime;
        updateProgress();
      });

      waveformHit.addEventListener("keydown", (event) => {
        if (!audio.duration) return;
        if (event.key === "ArrowRight") {
          event.preventDefault();
          audio.currentTime = Math.min(audio.duration, audio.currentTime + 5);
          updateProgress();
        }
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          audio.currentTime = Math.max(0, audio.currentTime - 5);
          updateProgress();
        }
        if (event.key === " " || event.key === "Enter") {
          event.preventDefault();
          toggle.click();
        }
      });

      audio.addEventListener("loadedmetadata", () => {
        updateDuration();
        updateProgress();
      });
      audio.addEventListener("timeupdate", updateProgress);
      audio.addEventListener("play", updateToggle);
      audio.addEventListener("pause", updateToggle);
      audio.addEventListener("volumechange", updateMute);
      audio.addEventListener("ended", () => {
        audio.currentTime = 0;
        updateProgress();
        updateToggle();
      });
      window.addEventListener("resize", drawWaveform);

      updateToggle();
      updateMute();
      updateProgress();
      drawWaveform();
      loadWaveform();
    });
  </script>
</SiteLayout>
