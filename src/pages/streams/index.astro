---
import SiteLayout from "../../layouts/SiteLayout.astro";
import InnerPage from "../../components/layout/InnerPage.astro";
import Footer from "../../components/layout/Footer.astro";
import StreamCard from "../../components/content/StreamCard.astro";
import streamsPayload from "../../data/streams.json";
import { getInnerPageNav } from "../../config/navigation";
import { formatCompactNumber, formatShortSpanishDate } from "../../lib/format";

const navItems = getInnerPageNav("/streams/");

const remixPlaylistUrl = "https://www.youtube.com/playlist?list=PL7GdsPwT1udakuOCTCLXEI8NliXaAm0PA";

const streams = streamsPayload.streams;
const profile = streamsPayload.profile;
const featuredStreams = streams.slice(0, 4);
const extraStreams = streams.slice(4);
const latestStream = streams[0];

const formatUpdated = formatShortSpanishDate(new Date(streamsPayload.generated_at));
---

<SiteLayout
  title="Marques Edition | Remixes"
  description="Remixes y edits de Marques Edition dentro de la web. Material propio publicado en YouTube y separado de la sección de sets."
>
  <InnerPage
    ariaLabel="Remixes de Marques Edition"
    eyebrow="Remixes"
    title="Aquí puedes ver mis remixes y edits publicados."
    description="Esta sección no es para sets largos. Aquí van remixes, edits y material propio publicado en YouTube, separado de la página de sets."
    navItems={navItems}
  >
    <Fragment slot="main">
      <section class="section" aria-labelledby="streams-title">
        <p class="section-kicker">Material propio</p>
        <h2 id="streams-title">Playlist de remixes publicada en YouTube</h2>
        <p class="section-copy">
          Aquí aparecen los remixes y edits publicados en la playlist <strong>REMIXES</strong>.
          Es una ruta separada para enseñar sonido propio sin mezclarlo con reels ni con la
          sección de sets largos.
        </p>

        {
          streams.length > 0 ? (
            <>
              <div class="streams">
                {featuredStreams.map((stream, index) => (
                  <StreamCard stream={stream} index={index + 1} isHero={index === 0} />
                ))}
              </div>

              {
                extraStreams.length > 0 && (
                  <details class="streams-more">
                    <summary class="streams-toggle">Ver más remixes ({streams.length})</summary>
                    <div class="streams">
                      {extraStreams.map((stream, index) => (
                        <StreamCard stream={stream} index={index + 5} />
                      ))}
                    </div>
            </details>
          )
        }
      </>
    ) : (
      <div class="empty-state">
        <strong>Todavía no hay remixes publicados en esta fuente.</strong>
        <p>
          Cuando la playlist de remixes tenga nuevos vídeos, aparecerán aquí automáticamente.
        </p>
      </div>
          )
        }
      </section>
    </Fragment>

    <Fragment slot="sidebar">
      <section class="side-card" aria-labelledby="latest-title">
        <p class="side-kicker">Último remix</p>
        <h2 id="latest-title">Lo más reciente de la playlist</h2>
        {
          latestStream ? (
            <div class="latest">
              <strong>{latestStream.title}</strong>
              <span>{latestStream.published_text} · {latestStream.duration || latestStream.status}</span>
            </div>
          ) : (
            <p class="side-note">Todavía no hay remixes publicados para mostrar aquí.</p>
          )
        }
      </section>

      <section class="side-card" aria-labelledby="stats-title">
        <p class="side-kicker">Canal</p>
        <h2 id="stats-title">Contexto rápido del bloque de remixes</h2>
        <div class="stats">
          <span class="stat">{formatCompactNumber(profile.subscribers)} suscriptores</span>
          <span class="stat">{streams.length} remixes</span>
          <span class="stat">{profile.videos} vídeos</span>
        </div>
      </section>

      <section class="side-card" aria-labelledby="fit-title">
        <p class="side-kicker">Cómo usar esta página</p>
        <h2 id="fit-title">Reels para cabina, remixes para escuchar sonido propio</h2>
        <p>
          Esta ruta enseña remixes, no sets largos. La página de sets ya queda separada para
          escuchar sesiones completas con reproductor propio.
        </p>

        <div class="facts" aria-label="Qué enseña esta página">
          <div class="fact">
            <strong>Formato</strong>
            <span>Remixes, edits y material propio publicado</span>
          </div>
          <div class="fact">
            <strong>Fuente</strong>
            <span>Playlist REMIXES de YouTube</span>
          </div>
        </div>

        <div class="side-stack">
          <a class="side-link" href="/booking/">Ir a booking ↗</a>
          <a class="side-link" href="/reels/">Ver reels ↗</a>
          <a class="side-link" href="/sets/">Ver sets ↗</a>
          <a class="side-link" href="/events/">Ver events ↗</a>
          <a class="side-link" href={remixPlaylistUrl} target="_blank" rel="noopener noreferrer">Abrir playlist REMIXES ↗</a>
        </div>
      </section>
    </Fragment>

    <Footer slot="footer" />
  </InnerPage>

  <p class="status-copy">
    {streams.length} remixes · actualizado {formatUpdated} ·
    <a href={remixPlaylistUrl} target="_blank" rel="noopener noreferrer">abrir playlist ↗</a>
  </p>

  <style>
    .streams {
      margin-top: 0.9rem;
      display: grid;
      gap: 0.85rem;
    }

    .latest,
    .fact,
    .empty-state {
      padding: 0.95rem;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.05);
    }

    .latest strong,
    .fact strong,
    .empty-state strong {
      display: block;
      font-size: 0.95rem;
    }

    .latest span,
    .fact span,
    .empty-state p,
    .side-note {
      display: block;
      margin-top: 0.24rem;
      color: var(--muted-strong);
      font-size: 0.82rem;
      line-height: 1.45;
    }

    .stats {
      margin-top: 0.9rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
    }

    .stat {
      min-height: 38px;
      padding: 0.6rem 0.86rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.06);
      color: #fff;
      font-size: 0.8rem;
      font-weight: 800;
    }

    .side-stack,
    .facts {
      display: grid;
      gap: 0.65rem;
    }

    .side-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 0.55rem 0.9rem;
      border-radius: 999px;
      border: 1px solid rgba(69, 215, 255, 0.28);
      background: rgba(69, 215, 255, 0.08);
      color: var(--blue);
      font-size: 0.82rem;
      font-weight: 800;
      text-decoration: none;
    }

    .streams-more {
      margin-top: 0.95rem;
    }

    .streams-toggle {
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 54px;
      padding: 0.9rem 1rem;
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
        linear-gradient(155deg, rgba(24, 51, 85, 0.54), rgba(18, 12, 44, 0.78));
      color: #f7f3ff;
      font-size: 0.9rem;
      font-weight: 800;
      cursor: pointer;
    }

    .streams-toggle::-webkit-details-marker {
      display: none;
    }

    .status-copy {
      width: min(100%, 1180px);
      margin: 0.9rem auto 0;
      color: var(--muted-strong);
      font-size: 0.88rem;
      line-height: 1.55;
      text-align: center;
    }

    .status-copy a {
      color: #dfe8ff;
      text-decoration: none;
    }
  </style>
</SiteLayout>
