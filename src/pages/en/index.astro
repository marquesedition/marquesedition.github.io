---
import { Image } from "astro:assets";
import profileImage from "../../assets/profile.png";
import SiteLayout from "../../layouts/SiteLayout.astro";
import EventsBoard from "../../components/content/EventsBoard.astro";
import Footer from "../../components/layout/Footer.astro";
import { buildAbsoluteUrl } from "../../config/site";
import { getLocaleHref } from "../../lib/i18n";
import { getEventsData, getReelsData, getStreamsData } from "../../lib/content";
import { formatCompactNumber, formatShortDate } from "../../lib/format";

const [{ reels, profile }, { streams }, { events, featuredResidency }] = await Promise.all([
  getReelsData(),
  getStreamsData(),
  getEventsData(),
]);

const latestReel = reels[0];
const residency = featuredResidency;
const publishedSets = 1;
const profileImageUrl = buildAbsoluteUrl(profileImage.src);
const homepageSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Marques Edition",
  url: "https://www.marquesedition.com/en/",
  image: profileImageUrl,
  jobTitle: "DJ in Madrid crossover",
  description:
    "Marques Edition is a crossover DJ in Madrid and resident at Pension Mimosas. Afro, latin, reggaeton and open format for clubs, weddings and private events.",
  homeLocation: {
    "@type": "Place",
    name: "Madrid, Spain",
  },
  knowsAbout: ["DJ in Madrid", "Madrid crossover DJ", "Afro", "Latin", "Reggaeton", "Open format"],
  sameAs: [
    "https://www.instagram.com/marquesedition/",
    "https://www.tiktok.com/@marquesedition",
    "https://www.youtube.com/@marquesedition",
    "https://open.spotify.com/user/k4d0hpomyssmueak9hh5wyvue?si=520ebb1aac944497",
  ],
};
---

<SiteLayout
  title="Marques Edition | DJ in Madrid Crossover"
  description="Marques Edition is a crossover DJ in Madrid and resident at Pension Mimosas. Afro, latin, reggaeton and open format for clubs, weddings and private events."
  lang="en"
  alternateHref={getLocaleHref("es", "/")}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(homepageSchema)} />
  </Fragment>

  <main class="page">
    <section class="quick-nav" aria-labelledby="quick-nav-title">
      <div class="quick-nav-copy">
        <p class="quick-nav-kicker">Direct paths</p>
        <h2 id="quick-nav-title">Pick the route that makes the most sense for you.</h2>
      </div>

      <div class="quick-nav-grid">
        <a class="quick-card" href="/reels/">
          <span class="quick-card-kicker">Live work</span>
          <strong>Reels</strong>
          <span class="quick-card-copy">Real booth moments, crowd energy and transitions.</span>
        </a>

        <a class="quick-card" href="/media-links/">
          <span class="quick-card-kicker">Platforms</span>
          <strong>Media Links</strong>
          <span class="quick-card-copy">Every official link in one place.</span>
        </a>

        <a class="quick-card" href="/streams/">
          <span class="quick-card-kicker">Original material</span>
          <strong>Remixes</strong>
          <span class="quick-card-copy">Published edits and remixes from the YouTube playlist.</span>
        </a>

        <a class="quick-card" href="/sets/">
          <span class="quick-card-kicker">Long-form listen</span>
          <strong>Sets</strong>
          <span class="quick-card-copy">Listen to a longer DJ session directly on the site.</span>
        </a>

        <a class="quick-card quick-card-primary" href="/en/booking/">
          <span class="quick-card-kicker">Enquiries</span>
          <strong>Booking</strong>
          <span class="quick-card-copy">Tell me about the date and I will reply with a proposal.</span>
        </a>
      </div>
    </section>

    <section class="hero" aria-label="Main presentation">
      <div class="hero-grid">
        <div class="hero-media">
          <Image
            class="hero-photo"
            src={profileImage}
            alt="Marques Edition performing"
            loading="eager"
            sizes="(max-width: 959px) 100vw, 60vw"
          />
          <div class="hero-content">
            <div class="topline">
              <span class="eyebrow">Marques Edition</span>
              <span class="status-pill">DJ in Madrid</span>
            </div>

            <div class="actions">
              <div>
                <h1>Club energy with a latin identity.</h1>
                <p class="lede">
                  I am Marques Edition, a crossover DJ based in Madrid. I mix afro, latin,
                  reggaeton and open format for clubs, weddings and private events where the dance
                  floor needs to respond for real.
                </p>
              </div>

              <div class="chips" aria-label="Music style">
                <span class="chip">Afro</span>
                <span class="chip">Latin</span>
                <span class="chip">Reggaeton</span>
                <span class="chip">Crossover</span>
                <span class="chip">Open format</span>
                <span class="chip">Live booth energy</span>
                <span class="chip">Resident @pensionmimosas</span>
              </div>

              <div class="cta-row">
                <a class="cta" href="/en/booking/">Booking enquiries ↗</a>
                <a class="cta-secondary" href="/en/about/">About ↗</a>
                <a class="cta-secondary" href="/reels/">See reels ↗</a>
                <a class="cta-secondary" href="/streams/">See remixes ↗</a>
                <a class="cta-secondary" href="/sets/">Listen to a set ↗</a>
                <a class="cta-secondary" href="/media-links/">Media links ↗</a>
              </div>
            </div>
          </div>
        </div>

        <aside class="hero-panel" aria-label="Social proof and latest reel">
          <p class="panel-kicker">Open booth</p>
          <h2 class="panel-title">Everything you need to understand how I work is here.</h2>
          <p class="panel-copy">
            Reels to see the booth in action, remixes to hear original material, a set page for
            longer listening, official links kept separate and a booking route focused on clubs,
            brands, weddings and private events.
          </p>

          <div class="stats" aria-label="Statistics">
            <div class="stat">
              <strong>{formatCompactNumber(profile.followers, "en-GB")}</strong>
              <span>Followers</span>
            </div>
            <div class="stat">
              <strong>{reels.length}</strong>
              <span>Reels</span>
            </div>
            <div class="stat">
              <strong>{streams.length}</strong>
              <span>Remixes</span>
            </div>
            <div class="stat">
              <strong>{publishedSets}</strong>
              <span>Sets</span>
            </div>
          </div>

          <div class="panel-divider"></div>

          <a
            class="latest-reel"
            href={latestReel.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Open latest reel: ${latestReel.title}`}
          >
            <p class="latest-label">Latest reel</p>
            <p class="latest-title">{latestReel.title}</p>
            <p class="latest-meta">{formatShortDate(latestReel.date, "en-GB")} · {latestReel.label}</p>
          </a>
        </aside>
      </div>
    </section>

    <section class="events-home" aria-labelledby="events-home-title">
      <div class="events-home-copy">
        <p class="events-home-kicker">Upcoming dates</p>
        <h2 id="events-home-title">Where I am playing next.</h2>
        <p class="events-home-desc">
          A clear month-by-month schedule with city, venue and direct access to tickets or venue
          info for each date.
        </p>
      </div>

      {
        residency && (
          <div class="residency-highlight">
            <div class="residency-highlight-copy">
              <p class="residency-label">Residency</p>
              <strong>{residency.schedule_label}</strong>
              <span>{residency.venue} · {residency.time_label}</span>
              <span>{residency.address}</span>
            </div>

            <div class="residency-highlight-actions">
              <a class="quick-card-link" href="/events/">See schedule ↗</a>
              <a class="quick-card-link" href={residency.map_url} target="_blank" rel="noopener noreferrer">Directions ↗</a>
            </div>
          </div>
        )
      }

      <EventsBoard
        events={events}
        previewLimit={4}
        moreHref="/events/"
        moreLabel="See all dates ↗"
        emptyTitle="No published dates yet."
        emptyCopy="This area is ready for upcoming shows as soon as we update the events feed."
      />
    </section>

    <section class="services" aria-label="Services">
      <article class="service-card service-card-wide">
        <h2>DJ in Madrid crossover for clubs, weddings and private events</h2>
        <p>
          If someone is looking for a crossover DJ in Madrid, this site makes the proposition
          clear: a dance-floor focused mix built with afro, latin, reggaeton, commercial hits and
          energy changes shaped around the room.
        </p>
        <p>
          The base is Madrid and the residency at Pension Mimosas reinforces a real presence in
          the booth. The goal is to adapt each set without losing identity.
        </p>
      </article>

      <article class="service-card">
        <h2>Clubs</h2>
        <p>I read the room, raise the tension at the right time and keep the energy moving.</p>
      </article>
      <article class="service-card">
        <h2>Private events</h2>
        <p>I adapt the set to the space and the crowd without losing my own sound.</p>
      </article>
      <article class="service-card">
        <h2>Weddings</h2>
        <p>I build flexible sets for mixed guests, changing tempos and a connected dance floor.</p>
      </article>
    </section>

    <Footer />
  </main>

  <style>
    .page {
      width: min(100%, 1180px);
      margin: 0 auto;
    }

    .quick-nav {
      margin-bottom: 1.1rem;
      padding: 1.05rem 1.05rem 1.1rem;
      border-radius: 28px;
      border: 1px solid rgba(171, 141, 255, 0.16);
      background:
        radial-gradient(420px 220px at 12% 10%, rgba(255, 90, 191, 0.1), transparent 68%),
        radial-gradient(380px 220px at 88% 16%, rgba(69, 215, 255, 0.08), transparent 70%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
        linear-gradient(160deg, rgba(90, 70, 180, 0.1), rgba(18, 12, 50, 0.12));
    }

    .quick-nav-copy {
      max-width: 38rem;
    }

    .quick-nav-kicker {
      margin: 0;
      color: #45d7ff;
      font-size: 0.74rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .quick-nav h2 {
      margin: 0.4rem 0 0;
      font-size: 1.18rem;
      line-height: 1.25;
    }

    .quick-nav-grid {
      margin-top: 1rem;
      display: grid;
      gap: 0.8rem;
    }

    .quick-card {
      display: grid;
      gap: 0.38rem;
      padding: 1.05rem;
      border-radius: 22px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.05);
      color: #fff;
      text-decoration: none;
      transition:
        transform 160ms ease,
        border-color 160ms ease,
        background 160ms ease,
        box-shadow 160ms ease;
    }

    .quick-card:hover,
    .quick-card:focus-visible {
      transform: translateY(-2px);
      border-color: rgba(69, 215, 255, 0.28);
      background: rgba(255, 255, 255, 0.08);
      box-shadow: 0 14px 30px rgba(5, 2, 20, 0.3);
      outline: none;
    }

    .quick-card-primary {
      background:
        linear-gradient(135deg, rgba(255, 90, 191, 0.16), rgba(69, 215, 255, 0.12)),
        rgba(255, 255, 255, 0.05);
    }

    .quick-card-kicker {
      color: #45d7ff;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .quick-card strong {
      font-size: 1.08rem;
      line-height: 1.16;
    }

    .quick-card-copy {
      color: #dde4f7;
      font-size: 0.88rem;
      line-height: 1.5;
    }

    .hero {
      position: relative;
      overflow: hidden;
      border-radius: 34px;
      border: 1px solid rgba(171, 141, 255, 0.2);
      background:
        radial-gradient(520px 320px at 18% 10%, rgba(255, 90, 191, 0.12), transparent 64%),
        radial-gradient(540px 340px at 82% 12%, rgba(69, 215, 255, 0.12), transparent 66%),
        linear-gradient(180deg, rgba(28, 18, 70, 0.9), rgba(14, 9, 38, 0.98));
      box-shadow: 0 28px 72px rgba(2, 0, 12, 0.56);
      padding: 1.05rem;
    }

    .hero-grid {
      display: grid;
      gap: 1.05rem;
    }

    .hero-media,
    .hero-panel {
      min-width: 0;
    }

    .hero-media {
      min-height: 740px;
      border-radius: 28px;
      overflow: hidden;
      position: relative;
      background: rgba(7, 4, 18, 0.2);
    }

    .hero-photo {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 24%;
    }

    .hero-content {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      padding: 1.15rem 1.15rem 1.35rem;
      background:
        radial-gradient(420px 220px at 12% 10%, rgba(255, 90, 191, 0.18), transparent 68%),
        radial-gradient(360px 220px at 88% 18%, rgba(69, 215, 255, 0.16), transparent 70%),
        linear-gradient(180deg, rgba(6, 3, 17, 0.18), rgba(6, 3, 17, 0.78));
    }

    .topline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      flex-wrap: wrap;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #45d7ff;
    }

    .status-pill,
    .chip {
      display: inline-flex;
      align-items: center;
      min-height: 36px;
      padding: 0.55rem 0.85rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(6, 3, 17, 0.5);
      color: #fff;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.03em;
      backdrop-filter: blur(14px);
    }

    .actions {
      display: grid;
      gap: 1rem;
      margin-top: auto;
    }

    h1 {
      margin: 0;
      max-width: 9.5ch;
      font-size: clamp(2.15rem, 7.6vw, 4.7rem);
      line-height: 0.92;
    }

    .lede {
      max-width: 34rem;
      margin: 0.8rem 0 0;
      color: #f0f4ff;
      font-size: 0.96rem;
      line-height: 1.6;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      align-items: flex-start;
    }

    .cta-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 0.7rem;
      align-items: stretch;
    }

    .cta,
    .cta-secondary {
      min-height: 50px;
      padding: 0.92rem 1rem;
      border-radius: 16px;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 900;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 0;
      text-align: center;
    }

    .cta {
      color: #160b34;
      background: linear-gradient(135deg, rgba(255, 90, 191, 0.96), rgba(69, 215, 255, 0.9));
    }

    .cta-secondary {
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.06);
    }

    .hero-panel {
      padding: 1.1rem;
      border-radius: 28px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
        linear-gradient(160deg, rgba(90, 70, 180, 0.12), rgba(18, 12, 50, 0.16));
    }

    .panel-kicker {
      margin: 0;
      color: #45d7ff;
      font-size: 0.74rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .panel-title {
      margin: 0.4rem 0 0;
      font-size: 1.15rem;
      line-height: 1.28;
    }

    .panel-copy {
      margin: 0.55rem 0 0;
      color: #dde4f7;
      font-size: 0.9rem;
      line-height: 1.58;
    }

    .stats {
      margin-top: 1rem;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 0.7rem;
    }

    .stat {
      padding: 0.95rem;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.05);
      display: grid;
      gap: 0.14rem;
    }

    .stat strong {
      font-size: 1.18rem;
      line-height: 1.1;
    }

    .stat span {
      color: #d8e2fb;
      font-size: 0.82rem;
      font-weight: 700;
    }

    .panel-divider {
      height: 1px;
      margin: 0.95rem 0;
      background: rgba(255, 255, 255, 0.08);
    }

    .latest-reel {
      display: grid;
      gap: 0.32rem;
      padding: 0.95rem;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.05);
      color: #fff;
      text-decoration: none;
    }

    .latest-label,
    .residency-label,
    .events-home-kicker {
      margin: 0;
      color: #45d7ff;
      font-size: 0.74rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .latest-title {
      margin: 0;
      font-size: 1rem;
      line-height: 1.35;
    }

    .latest-meta,
    .events-home-desc {
      margin: 0;
      color: #d8e2fb;
      font-size: 0.86rem;
      line-height: 1.5;
    }

    .events-home,
    .services {
      margin-top: 1.1rem;
    }

    .events-home {
      padding: 1.1rem;
      border-radius: 28px;
      border: 1px solid rgba(171, 141, 255, 0.16);
      background:
        radial-gradient(420px 220px at 12% 10%, rgba(69, 215, 255, 0.08), transparent 68%),
        radial-gradient(380px 220px at 88% 16%, rgba(255, 90, 191, 0.06), transparent 70%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
        linear-gradient(160deg, rgba(90, 70, 180, 0.1), rgba(18, 12, 50, 0.12));
    }

    .events-home-copy {
      max-width: 42rem;
    }

    .events-home h2 {
      margin: 0.4rem 0 0;
      font-size: 1.18rem;
      line-height: 1.25;
    }

    .events-home-desc {
      margin-top: 0.5rem;
    }

    .residency-highlight {
      margin: 1rem 0;
      padding: 1rem;
      border-radius: 22px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.05);
      display: grid;
      gap: 0.85rem;
    }

    .residency-highlight-copy {
      display: grid;
      gap: 0.24rem;
    }

    .residency-highlight-copy strong {
      font-size: 1rem;
      line-height: 1.2;
    }

    .residency-highlight-copy span {
      color: #d8e2fb;
      font-size: 0.84rem;
      line-height: 1.45;
    }

    .residency-highlight-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
    }

    .quick-card-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 0.55rem 0.9rem;
      border-radius: 999px;
      border: 1px solid rgba(69, 215, 255, 0.28);
      background: rgba(69, 215, 255, 0.08);
      color: var(--blue);
      font-size: 0.82rem;
      font-weight: 800;
      text-decoration: none;
    }

    .services {
      display: grid;
      gap: 0.85rem;
    }

    .service-card {
      padding: 1rem;
      border-radius: 22px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
        linear-gradient(160deg, rgba(90, 70, 180, 0.12), rgba(18, 12, 50, 0.16));
    }

    .service-card h2 {
      margin: 0;
      font-size: 1.02rem;
      line-height: 1.28;
    }

    .service-card p {
      margin: 0.52rem 0 0;
      color: #dde4f7;
      font-size: 0.88rem;
      line-height: 1.58;
    }

    @media (min-width: 960px) {
      .quick-nav-grid,
      .services {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .quick-card-primary,
      .service-card-wide {
        grid-column: span 2;
      }

      .hero-grid {
        grid-template-columns: minmax(0, 1.3fr) minmax(320px, 0.7fr);
      }

      .stats {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 560px) {
      .hero {
        padding: 0.8rem;
        border-radius: 28px;
      }

      .hero-media {
        min-height: 660px;
        border-radius: 22px;
      }

      .hero-content {
        padding: 0.95rem 0.95rem 1.1rem;
      }

      h1 {
        max-width: 10.5ch;
      }

      .quick-nav,
      .events-home {
        padding: 0.9rem;
        border-radius: 22px;
      }
    }
  </style>
</SiteLayout>
