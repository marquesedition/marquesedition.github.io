---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import InnerPage from "../../../components/layout/InnerPage.astro";
import Footer from "../../../components/layout/Footer.astro";
import { getInnerPageNav } from "../../../config/navigation";
import { getLocaleHref } from "../../../lib/i18n";

const navItems = getInnerPageNav("/booking/", "en");
---

<SiteLayout
  title="Marques Edition | Booking"
  description="Booking page for Marques Edition. Guided form for clubs, weddings, brands and private events."
  lang="en"
  alternateHref={getLocaleHref("es", "/booking/")}
>
  <InnerPage
    ariaLabel="Booking for Marques Edition"
    eyebrow="Booking"
    title="If you want to lock in a date, this is where the conversation starts."
    description="This space is built for clubs, weddings, brands and private events. Fill in the brief, review the summary and send the request with everything clear from the first message."
    navItems={navItems}
  >
    <Fragment slot="main">
      <div class="chip-row" aria-label="Formats">
        <span class="chip">Clubs</span>
        <span class="chip">Weddings</span>
        <span class="chip">Private events</span>
        <span class="chip">Brands</span>
        <span class="chip">Open format</span>
      </div>

      <section class="section" aria-labelledby="process-title">
        <p class="section-kicker">Process</p>
        <h2 id="process-title">The goal is to move quickly and keep things clear.</h2>
        <p class="section-copy">
          The clearer the event context is from the start, the easier it is to reply with a solid
          proposal in the first answer.
        </p>

        <div class="steps" aria-label="Booking steps">
          <div class="step">
            <strong>1. Fill in the key details</strong>
            <span>Date, format, venue, time, capacity and technical situation.</span>
          </div>
          <div class="step">
            <strong>2. Build the summary</strong>
            <span>The site organises everything and shows exactly what will be sent.</span>
          </div>
          <div class="step">
            <strong>3. Confirm and send</strong>
            <span>The request goes out with a clean brief ready for the next conversation.</span>
          </div>
        </div>
      </section>

      <section class="contact-card" id="booking-form" aria-labelledby="booking-form-title">
        <p class="section-kicker">Form</p>
        <h2 id="booking-form-title">Tell me about the date and I will reply with a proposal</h2>
        <p class="contact-note">
          Fill in the core event details, build the summary and confirm the submission. That way I
          receive a clear brief from the first contact.
        </p>

        <form class="contact-form" id="booking-request-form" novalidate>
          <input type="hidden" name="_subject" value="New request from marquesedition.com" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="event_summary" id="contact-summary-input" />

          <div class="contact-grid">
            <div class="form-field">
              <label for="contact-name">Name</label>
              <input id="contact-name" name="name" type="text" autocomplete="name" placeholder="Your name or promoter name" required />
            </div>

            <div class="form-field">
              <label for="contact-email">Email</label>
              <input id="contact-email" name="email" type="email" autocomplete="email" placeholder="name@company.com" required />
            </div>

            <div class="form-field">
              <label for="contact-phone">Phone / WhatsApp</label>
              <input id="contact-phone" name="phone" type="text" autocomplete="tel" placeholder="+34 ..." />
            </div>

            <div class="form-field">
              <label for="contact-event-type">Format</label>
              <select id="contact-event-type" name="event_type" required>
                <option value="">Choose one</option>
                <option>Club</option>
                <option>Private event</option>
                <option>Wedding</option>
                <option>Brand</option>
                <option>Other</option>
              </select>
            </div>

            <div class="form-field">
              <label for="contact-date">Date</label>
              <input id="contact-date" name="event_date" type="date" required />
            </div>

            <div class="form-field">
              <label for="contact-location">City / venue</label>
              <input id="contact-location" name="location" type="text" autocomplete="address-level2" placeholder="Madrid / venue name" required />
            </div>

            <div class="form-field">
              <label for="contact-start-time">Start time</label>
              <input id="contact-start-time" name="start_time" type="time" required />
            </div>

            <div class="form-field">
              <label for="contact-set-length">Set length</label>
              <select id="contact-set-length" name="set_length" required>
                <option value="">Choose one</option>
                <option>1 hour</option>
                <option>2 hours</option>
                <option>3 hours</option>
                <option>4 hours</option>
                <option>5 hours or more</option>
                <option>Full session</option>
              </select>
            </div>

            <div class="form-field">
              <label for="contact-audience">Capacity / guests</label>
              <select id="contact-audience" name="audience" required>
                <option value="">Choose one</option>
                <option>Up to 80 people</option>
                <option>80 to 150 people</option>
                <option>150 to 300 people</option>
                <option>More than 300 people</option>
              </select>
            </div>

            <div class="form-field">
              <label for="contact-setup">Production / equipment</label>
              <select id="contact-setup" name="setup" required>
                <option value="">Choose one</option>
                <option>Full venue setup already in place</option>
                <option>Basic booth and sound available</option>
                <option>We need a technical proposal</option>
                <option>Still to be defined</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label for="contact-notes">Extra notes</label>
              <textarea id="contact-notes" name="notes" placeholder="Audience profile, key styles, full schedule or any useful detail."></textarea>
            </div>
          </div>

          <div class="form-actions">
            <div class="summary-tools">
              <button class="summary-build" id="build-summary" type="button">Build event summary</button>
              <div class="summary-card" id="summary-card" data-ready="false">
                <strong>Summary before sending</strong>
                <p id="summary-preview">There is no summary yet. Fill in the fields and click “Build event summary”.</p>
              </div>
              <div class="confirm-row">
                <input id="confirm-summary" name="confirm_summary" type="checkbox" value="yes" />
                <label for="confirm-summary">I have reviewed the summary and confirm these details are correct for sending the request.</label>
              </div>
            </div>

            <button class="form-submit" type="submit" disabled>Confirm and send request</button>
            <p class="form-status" id="form-status">
              Complete the fields, build the summary and confirm the submission.
            </p>
          </div>
        </form>
      </section>
    </Fragment>

    <Fragment slot="sidebar">
      <section class="side-card" aria-labelledby="fit-title">
        <p class="side-kicker">What helps most</p>
        <h2 id="fit-title">The details that make a proper reply possible</h2>
        <p>
          Date, event type, capacity, schedule and technical starting point. With that, the real
          fit can already be assessed properly.
        </p>

        <div class="brief-points" aria-label="Booking details">
          <p class="brief-point"><strong>Date:</strong> confirmed event day.</p>
          <p class="brief-point"><strong>Venue:</strong> city, space and format.</p>
          <p class="brief-point"><strong>Set:</strong> duration and play time.</p>
          <p class="brief-point"><strong>Production:</strong> what is already available and what is missing.</p>
        </div>
      </section>

      <section class="side-card" aria-labelledby="profile-title">
        <p class="side-kicker">Profile</p>
        <h2 id="profile-title">Marques Edition</h2>
        <p>
          Madrid-based DJ with afro, latin and open format sets. A booth approach built around
          reading the room, holding the energy and adapting without losing identity.
        </p>

        <div class="facts" aria-label="Quick facts">
          <span class="fact-chip">Base: Madrid</span>
          <span class="fact-chip">Afro / Latin / Open format</span>
          <span class="fact-chip">Clubs / Weddings / Private events</span>
          <span class="fact-chip">Residency @pensionmimosas</span>
        </div>
      </section>

      <section class="side-card" aria-labelledby="genres-title">
        <p class="side-kicker">What often works</p>
        <h2 id="genres-title">Styles that usually connect with broad crowds in Spain</h2>
        <p>
          For mixed audiences, the strongest response usually comes from a measured blend of pop,
          latin urban, danceable latin blocks and recent classics.
        </p>

        <div class="facts" aria-label="Genres that usually work best">
          <span class="fact-chip">Spanish pop</span>
          <span class="fact-chip">International pop</span>
          <span class="fact-chip">Latin pop</span>
          <span class="fact-chip">Spanish pop-rock</span>
          <span class="fact-chip">International pop-rock</span>
          <span class="fact-chip">Reggaeton</span>
          <span class="fact-chip">Latin urban</span>
          <span class="fact-chip">Afrobeat / afropop</span>
          <span class="fact-chip">Bachata</span>
          <span class="fact-chip">Merengue / merenguetón</span>
          <span class="fact-chip">Commercial dance</span>
          <span class="fact-chip">Commercial electronic</span>
          <span class="fact-chip">Flamenco pop</span>
          <span class="fact-chip">Spanish classics</span>
          <span class="fact-chip">Hits 2000s / 2010s / 2020s</span>
        </div>
      </section>

      <section class="side-card" aria-labelledby="links-title">
        <p class="side-kicker">Navigation</p>
        <h2 id="links-title">Before or after booking</h2>
        <p>
          If you want to review work or official platforms first, those routes are separated and
          ready for that.
        </p>

        <div class="side-stack">
          <a class="side-link" href="/reels/">See reels ↗</a>
          <a class="side-link" href="/streams/">See remixes ↗</a>
          <a class="side-link" href="/sets/">See sets ↗</a>
          <a class="side-link" href="/events/">See events ↗</a>
          <a class="side-link" href="/media-links/">Open media-links ↗</a>
          <a class="side-link" href="https://www.instagram.com/marquesedition/reels/" target="_blank" rel="noopener noreferrer">Open Instagram reels ↗</a>
        </div>
      </section>
    </Fragment>

    <Footer slot="footer" />
  </InnerPage>

  <script is:inline>
    // @ts-nocheck
    const BOOKING_FORM_ENDPOINT = "https://formsubmit.co/ajax/bookings@marquesedition.com";

    document.addEventListener("DOMContentLoaded", () => {
      const bookingForm = document.getElementById("booking-request-form");
      const formStatus = document.getElementById("form-status");
      const summaryButton = document.getElementById("build-summary");
      const summaryPreview = document.getElementById("summary-preview");
      const summaryCard = document.getElementById("summary-card");
      const summaryInput = document.getElementById("contact-summary-input");
      const confirmSummary = document.getElementById("confirm-summary");

      if (!bookingForm || !formStatus) return;

      const submitButton = bookingForm.querySelector(".form-submit");
      let summaryConfirmed = false;

      function setSubmitState() {
        if (submitButton) submitButton.disabled = !summaryConfirmed;
      }

      function formatDate(dateValue) {
        if (!dateValue) return "date pending";
        const date = new Date(dateValue + "T12:00:00");
        if (Number.isNaN(date.getTime())) return dateValue;

        return new Intl.DateTimeFormat("en-GB", {
          day: "numeric",
          month: "long",
          year: "numeric",
        }).format(date);
      }

      function resetSummaryState() {
        summaryConfirmed = false;
        if (confirmSummary) confirmSummary.checked = false;
        if (summaryCard) summaryCard.dataset.ready = "false";
        setSubmitState();
      }

      function buildSummary() {
        const name = bookingForm.elements.name.value.trim();
        const email = bookingForm.elements.email.value.trim();
        const phone = bookingForm.elements.phone.value.trim();
        const eventType = bookingForm.elements.event_type.value.trim();
        const eventDate = bookingForm.elements.event_date.value;
        const location = bookingForm.elements.location.value.trim();
        const startTime = bookingForm.elements.start_time.value;
        const setLength = bookingForm.elements.set_length.value.trim();
        const audience = bookingForm.elements.audience.value.trim();
        const setup = bookingForm.elements.setup.value.trim();
        const notes = bookingForm.elements.notes.value.trim();

        const lines = [
          `Request from ${name} for ${eventType.toLowerCase()}.`,
          `Date: ${formatDate(eventDate)}.`,
          `Location: ${location}.`,
          `Planned start: ${startTime}.`,
          `Requested set length: ${setLength}.`,
          `Estimated capacity: ${audience}.`,
          `Production available: ${setup}.`,
          `Contact: ${email}${phone ? " · " + phone : ""}.`,
        ];

        if (notes) lines.push(`Notes: ${notes}.`);
        return lines.join("\n");
      }

      function refreshSummary() {
        if (!bookingForm.reportValidity()) {
          formStatus.dataset.state = "error";
          formStatus.textContent = "Complete the required fields to build the summary.";
          return;
        }

        const summary = buildSummary();
        if (summaryPreview) summaryPreview.textContent = summary;
        if (summaryInput) summaryInput.value = summary;
        if (summaryCard) summaryCard.dataset.ready = "true";

        summaryConfirmed = false;
        if (confirmSummary) confirmSummary.checked = false;
        setSubmitState();

        formStatus.dataset.state = "success";
        formStatus.textContent = "Summary ready. Review it and confirm before sending.";
      }

      bookingForm.querySelectorAll("input, select, textarea").forEach((field) => {
        if (field.id !== "confirm-summary") {
          field.addEventListener("input", resetSummaryState);
          field.addEventListener("change", resetSummaryState);
        }
      });

      if (summaryButton) summaryButton.addEventListener("click", refreshSummary);

      if (confirmSummary) {
        confirmSummary.addEventListener("change", () => {
          summaryConfirmed = Boolean(confirmSummary.checked && summaryInput && summaryInput.value.trim());
          setSubmitState();

          if (summaryConfirmed) {
            formStatus.dataset.state = "success";
            formStatus.textContent = "Everything is ready. You can send the request now.";
          }
        });
      }

      bookingForm.addEventListener("submit", async (event) => {
        event.preventDefault();

        if (!bookingForm.reportValidity()) {
          formStatus.dataset.state = "error";
          formStatus.textContent = "Check the highlighted fields and try again.";
          return;
        }

        if (!summaryInput || !summaryInput.value.trim()) {
          formStatus.dataset.state = "error";
          formStatus.textContent = "Build the event summary first.";
          return;
        }

        if (!confirmSummary || !confirmSummary.checked) {
          formStatus.dataset.state = "error";
          formStatus.textContent = "Review the summary and confirm it before sending.";
          return;
        }

        const formData = new FormData(bookingForm);
        formStatus.dataset.state = "loading";
        formStatus.textContent = "Sending request...";
        if (submitButton) submitButton.disabled = true;

        try {
          const response = await fetch(BOOKING_FORM_ENDPOINT, {
            method: "POST",
            headers: { Accept: "application/json" },
            body: formData,
          });

          if (!response.ok) throw new Error("submit_failed");

          bookingForm.reset();
          if (summaryPreview) {
            summaryPreview.textContent = "There is no summary yet. Fill in the fields and click “Build event summary”.";
          }
          if (summaryInput) summaryInput.value = "";
          if (summaryCard) summaryCard.dataset.ready = "false";
          summaryConfirmed = false;
          setSubmitState();
          formStatus.dataset.state = "success";
          formStatus.textContent = "Request sent. I will reply as soon as I review the date.";
        } catch {
          formStatus.dataset.state = "error";
          formStatus.textContent = "The form could not be sent right now. The booking route remains static-friendly for GitHub Pages, so the email gateway needs to stay available.";
        } finally {
          if (submitButton) submitButton.disabled = false;
        }
      });
    });
  </script>

  <style>
    .steps,
    .facts,
    .side-stack,
    .summary-tools,
    .form-actions {
      display: grid;
      gap: 0.65rem;
    }

    .step,
    .brief-point,
    .summary-card {
      padding: 0.82rem 0.9rem;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.05);
    }

    .step strong,
    .summary-card strong {
      display: block;
      font-size: 0.9rem;
    }

    .step span,
    .brief-point,
    .summary-card p {
      display: block;
      margin-top: 0.24rem;
      color: var(--muted-strong);
      font-size: 0.82rem;
      line-height: 1.45;
    }

    .contact-card {
      margin-top: 1rem;
      padding: 1rem;
      border-radius: 22px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background:
        radial-gradient(320px 180px at 0% 0%, rgba(255, 90, 191, 0.12), transparent 70%),
        radial-gradient(320px 180px at 100% 12%, rgba(69, 215, 255, 0.12), transparent 72%),
        linear-gradient(155deg, rgba(36, 24, 85, 0.52), rgba(18, 12, 44, 0.82));
    }

    .contact-card h2 {
      margin: 0;
      font-size: 1.08rem;
      line-height: 1.25;
    }

    .contact-note {
      margin: 0.55rem 0 0;
      color: var(--muted-strong);
      font-size: 0.88rem;
      line-height: 1.55;
    }

    .contact-form {
      margin-top: 0.95rem;
      display: grid;
      gap: 0.78rem;
    }

    .contact-grid {
      display: grid;
      gap: 0.78rem;
    }

    .form-field {
      display: grid;
      gap: 0.42rem;
    }

    .form-field label {
      color: #f7f3ff;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.03em;
    }

    .form-field input,
    .form-field select,
    .form-field textarea {
      width: 100%;
      min-height: 50px;
      padding: 0.82rem 0.95rem;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.06);
      color: #fff;
      font: inherit;
    }

    .form-field textarea {
      min-height: 150px;
      resize: vertical;
    }

    .form-field select {
      appearance: none;
    }

    .form-field--full {
      grid-column: 1 / -1;
    }

    .summary-build,
    .form-submit {
      min-height: 48px;
      border: 0;
      border-radius: 16px;
      font: inherit;
      font-weight: 900;
      cursor: pointer;
      transition:
        transform 160ms ease,
        box-shadow 160ms ease,
        opacity 160ms ease;
    }

    .summary-build {
      color: #160b34;
      background: linear-gradient(135deg, rgba(255, 90, 191, 0.96), rgba(69, 215, 255, 0.9));
    }

    .form-submit {
      color: #fff;
      background: rgba(255, 255, 255, 0.1);
    }

    .form-submit:disabled {
      opacity: 0.45;
      cursor: not-allowed;
    }

    .summary-build:hover,
    .summary-build:focus-visible,
    .form-submit:hover:not(:disabled),
    .form-submit:focus-visible:not(:disabled) {
      transform: translateY(-1px);
      box-shadow: 0 12px 24px rgba(8, 3, 25, 0.34);
      outline: none;
    }

    .confirm-row {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.65rem;
      align-items: start;
    }

    .confirm-row input {
      margin-top: 0.2rem;
    }

    .confirm-row label,
    .form-status {
      color: var(--muted-strong);
      font-size: 0.82rem;
      line-height: 1.5;
    }

    .form-status[data-state="success"] {
      color: #8bf3cb;
    }

    .form-status[data-state="error"] {
      color: #ffb2cc;
    }

    .side-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 0.55rem 0.9rem;
      border-radius: 999px;
      border: 1px solid rgba(69, 215, 255, 0.28);
      background: rgba(69, 215, 255, 0.08);
      color: var(--blue);
      font-size: 0.82rem;
      font-weight: 800;
      text-decoration: none;
    }

    @media (min-width: 900px) {
      .contact-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
  </style>
</SiteLayout>
