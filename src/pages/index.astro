---
import SiteLayout from "../layouts/SiteLayout.astro";
import Footer from "../components/Footer.astro";
import reelsPayload from "../data/reels.json";

const latestReel = reelsPayload.reels[0];
const profile = reelsPayload.profile;

const formatCompactNumber = (value: number) => {
  if (value >= 1000) {
    const whole = value / 1000;
    return Number.isInteger(whole) ? `${whole.toFixed(0)}k` : `${whole.toFixed(1).replace(".", ",")}k`;
  }
  return String(value);
};

const formatDisplayDate = (dateValue: string) => {
  const date = new Date(`${dateValue}T12:00:00`);
  return new Intl.DateTimeFormat("es-ES", {
    day: "numeric",
    month: "short",
    year: "numeric",
  }).format(date);
};
---

<SiteLayout
  title="Marques Edition | DJ Madrid"
  description="Marques Edition es DJ en Madrid. Afro, latin y open format para clubs, bodas y eventos privados. Reels, enlaces y contrataciones en un solo sitio."
>
  <main class="page">
    <section class="hero" aria-label="Presentación principal">
      <div class="hero-grid">
        <div class="hero-media">
          <div class="hero-content">
            <div class="topline">
              <span class="eyebrow">Marques Edition</span>
              <span class="status-pill">DJ en Madrid</span>
            </div>

            <div class="actions">
              <div>
                <h1>Energía de club con identidad latina.</h1>
                <p class="lede">
                  Soy Marques Edition, DJ en Madrid. Mezclo afro, latin y open format para clubs,
                  bodas y eventos privados donde la pista tiene que responder de verdad.
                </p>
              </div>

              <div class="chips" aria-label="Estilo musical">
                <span class="chip">Afro</span>
                <span class="chip">Latin</span>
                <span class="chip">Open format</span>
                <span class="chip">Cabina en vivo</span>
                <span class="chip">Residente @pensionmimosas</span>
              </div>

              <div class="cta-row">
                <a class="cta" href="/booking/">Contrataciones ↗</a>
                <a class="cta-secondary" href="/reels/">Ver reels ↗</a>
              </div>
            </div>
          </div>
        </div>

        <aside class="hero-panel" aria-label="Prueba social y latest reel">
          <p class="panel-kicker">Cabina abierta</p>
          <h2 class="panel-title">Aquí está todo lo que necesitas para entender cómo trabajo.</h2>
          <p class="panel-copy">
            Reels para ver un poco de mi trabajo, enlaces oficiales por un lado y una ruta de
            booking aparte para hablar conmigo sobre clubs, marcas, bodas y eventos privados.
          </p>

          <div class="stats" aria-label="Estadísticas">
            <div class="stat">
              <strong>{formatCompactNumber(profile.followers)}</strong>
              <span>Seguidores</span>
            </div>
            <div class="stat">
              <strong>{reelsPayload.reels.length}</strong>
              <span>Reels</span>
            </div>
            <div class="stat">
              <strong>{profile.posts}</strong>
              <span>Posts</span>
            </div>
            <div class="stat">
              <strong>{profile.highlights}</strong>
              <span>Highlights</span>
            </div>
          </div>

          <div class="panel-divider"></div>

          <div class="latest-reel">
            <p class="latest-label">Último reel</p>
            <p class="latest-title">{latestReel.title}</p>
            <p class="latest-meta">{formatDisplayDate(latestReel.date)} · {latestReel.label}</p>
          </div>
        </aside>
      </div>
    </section>

    <section class="services" aria-label="Servicios">
      <article class="service-card">
        <h2>Clubs</h2>
        <p>
          Leo la pista, subo la tensión en el momento justo y mantengo la energía arriba durante
          toda la noche.
        </p>
      </article>
      <article class="service-card">
        <h2>Eventos privados</h2>
        <p>
          Adapto el set al espacio y al público sin perder mi identidad: afro, latin y crossover
          con criterio.
        </p>
      </article>
      <article class="service-card">
        <h2>Bodas</h2>
        <p>
          Construyo sesiones para invitados distintos, cambios de ritmo y una pista conectada desde
          el primer tema hasta el cierre.
        </p>
      </article>
    </section>

    <p class="site-note">
      Para ver trabajo entra en <a href="/reels/">reels</a>. Para enlaces oficiales entra en
      <a href="/media-links/">media-links</a>. Para contrataciones entra en
      <a href="/booking/">booking</a>.
    </p>

    <Footer />
  </main>

  <style>
    .page {
      width: min(100%, 1180px);
      margin: 0 auto;
    }

    .hero {
      position: relative;
      overflow: hidden;
      border-radius: 34px;
      border: 1px solid rgba(171, 141, 255, 0.2);
      background:
        radial-gradient(520px 320px at 18% 10%, rgba(255, 90, 191, 0.12), transparent 64%),
        radial-gradient(540px 340px at 82% 12%, rgba(69, 215, 255, 0.12), transparent 66%),
        linear-gradient(180deg, rgba(28, 18, 70, 0.9), rgba(14, 9, 38, 0.98));
      box-shadow: 0 28px 72px rgba(2, 0, 12, 0.56);
      padding: 1rem;
    }

    .hero-grid {
      display: grid;
      gap: 1rem;
    }

    .hero-media,
    .hero-panel {
      min-width: 0;
    }

    .hero-media {
      min-height: 450px;
      border-radius: 28px;
      background:
        linear-gradient(180deg, rgba(7, 4, 18, 0.2), rgba(7, 4, 18, 0.62)),
        url("/profile.png") center 24% / cover no-repeat;
      overflow: hidden;
      position: relative;
    }

    .hero-content {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 1rem;
      background:
        radial-gradient(420px 220px at 12% 10%, rgba(255, 90, 191, 0.18), transparent 68%),
        radial-gradient(360px 220px at 88% 18%, rgba(69, 215, 255, 0.16), transparent 70%),
        linear-gradient(180deg, rgba(6, 3, 17, 0.18), rgba(6, 3, 17, 0.78));
    }

    .topline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #45d7ff;
    }

    .status-pill,
    .chip {
      display: inline-flex;
      align-items: center;
      min-height: 36px;
      padding: 0.55rem 0.85rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(6, 3, 17, 0.5);
      color: #fff;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.03em;
      backdrop-filter: blur(14px);
    }

    .actions {
      display: grid;
      gap: 0.9rem;
    }

    h1 {
      margin: 0;
      max-width: 8.5ch;
      font-size: clamp(2.15rem, 7.6vw, 4.7rem);
      line-height: 0.92;
    }

    .lede {
      max-width: 32rem;
      margin: 0.8rem 0 0;
      color: #f0f4ff;
      font-size: 0.96rem;
      line-height: 1.6;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
    }

    .cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
    }

    .cta,
    .cta-secondary {
      min-height: 50px;
      padding: 0.88rem 1rem;
      border-radius: 16px;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 900;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .cta {
      color: #160b34;
      background: linear-gradient(135deg, rgba(255, 90, 191, 0.96), rgba(69, 215, 255, 0.9));
    }

    .cta-secondary {
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.06);
    }

    .hero-panel {
      padding: 1rem;
      border-radius: 28px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
        linear-gradient(160deg, rgba(90, 70, 180, 0.12), rgba(18, 12, 50, 0.16));
    }

    .panel-kicker {
      margin: 0;
      color: #45d7ff;
      font-size: 0.74rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .panel-title {
      margin: 0.4rem 0 0;
      font-size: 1.15rem;
      line-height: 1.28;
    }

    .panel-copy {
      margin: 0.55rem 0 0;
      color: #dde4f7;
      font-size: 0.9rem;
      line-height: 1.58;
    }

    .stats {
      margin-top: 0.95rem;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.7rem;
    }

    .stat {
      padding: 0.82rem;
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.05);
    }

    .stat strong {
      display: block;
      font-size: 1rem;
    }

    .stat span {
      display: block;
      margin-top: 0.22rem;
      color: #bec8e3;
      font-size: 0.76rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    .panel-divider {
      height: 1px;
      margin: 0.95rem 0;
      background: rgba(255, 255, 255, 0.08);
    }

    .latest-label,
    .latest-title,
    .latest-meta {
      margin: 0;
    }

    .latest-label {
      color: #45d7ff;
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .latest-title {
      margin-top: 0.45rem;
      font-size: 1rem;
      line-height: 1.4;
    }

    .latest-meta {
      margin-top: 0.35rem;
      color: #c2cae2;
      font-size: 0.82rem;
      font-weight: 700;
    }

    .services {
      margin-top: 1rem;
      display: grid;
      gap: 0.85rem;
    }

    .service-card {
      padding: 1rem;
      border-radius: 24px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
        linear-gradient(160deg, rgba(90, 70, 180, 0.12), rgba(18, 12, 50, 0.16));
    }

    .service-card h2 {
      margin: 0;
      font-size: 1.05rem;
    }

    .service-card p {
      margin: 0.5rem 0 0;
      color: #dde4f7;
      font-size: 0.9rem;
      line-height: 1.58;
    }

    .site-note {
      margin: 1rem 0 0;
      color: #c6bddf;
      font-size: 0.88rem;
      line-height: 1.58;
      text-align: center;
    }

    .site-note a {
      color: #dfe8ff;
      text-decoration: none;
    }

    @media (min-width: 900px) {
      .hero {
        padding: 1.15rem;
      }

      .hero-grid {
        grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.72fr);
      }

      .hero-content {
        padding: 1.2rem;
      }

      .services {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
  </style>
</SiteLayout>
