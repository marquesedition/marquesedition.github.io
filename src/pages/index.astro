---
import { Image } from "astro:assets";
import profileImage from "../assets/profile.png";
import SiteLayout from "../layouts/SiteLayout.astro";
import EventsBoard from "../components/content/EventsBoard.astro";
import Footer from "../components/layout/Footer.astro";
import { buildAbsoluteUrl } from "../config/site";
import { getLocaleHref } from "../lib/i18n";
import { getEventsData, getReelsData, getStreamsData } from "../lib/content";
import { formatCompactNumber, formatShortSpanishDate } from "../lib/format";

const [{ reels, profile }, { streams }, { events, featuredResidency }] = await Promise.all([
  getReelsData(),
  getStreamsData(),
  getEventsData(),
]);

const latestReel = reels[0];
const residency = featuredResidency;
const publishedSets = 1;
const profileImageUrl = buildAbsoluteUrl(profileImage.src);
const homepageSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Marques Edition",
  url: "https://www.marquesedition.com/",
  image: profileImageUrl,
  jobTitle: "DJ en Madrid crossover",
  description:
    "Marques Edition es DJ en Madrid crossover y residente en Pensión Mimosas. Mezcla afro, latin, reggaeton y open format para clubs, bodas y eventos privados.",
  homeLocation: {
    "@type": "Place",
    name: "Madrid, Spain",
  },
  knowsAbout: ["DJ en Madrid", "DJ en Madrid crossover", "Afro", "Latin", "Reggaeton", "Open format"],
  sameAs: [
    "https://www.instagram.com/marquesedition/",
    "https://www.tiktok.com/@marquesedition",
    "https://www.youtube.com/@marquesedition",
    "https://open.spotify.com/user/k4d0hpomyssmueak9hh5wyvue?si=520ebb1aac944497",
  ],
};

---

<SiteLayout
  title="Marques Edition | DJ en Madrid Crossover"
  description="Marques Edition es DJ en Madrid crossover y residente en Pensión Mimosas. Afro, latin, reggaeton y open format para clubs, bodas y eventos privados."
  lang="es"
  alternateHref={getLocaleHref("en", "/")}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(homepageSchema)} />
  </Fragment>

  <main class="page">
    <section class="quick-nav" aria-labelledby="quick-nav-title">
      <div class="quick-nav-copy">
        <p class="quick-nav-kicker">Entrada directa</p>
        <h2 id="quick-nav-title">Elige la ruta según lo que necesitas.</h2>
      </div>

      <div class="quick-nav-grid">
        <a class="quick-card" href="/reels/">
          <span class="quick-card-kicker">Trabajo real</span>
          <strong>Reels</strong>
          <span class="quick-card-copy">Pista, mezcla y cabina en acción.</span>
        </a>

        <a class="quick-card" href="/media-links/">
          <span class="quick-card-kicker">Plataformas</span>
          <strong>Media Links</strong>
          <span class="quick-card-copy">Todos mis enlaces oficiales en un solo sitio.</span>
        </a>

        <a class="quick-card" href="/streams/">
          <span class="quick-card-kicker">Material propio</span>
          <strong>Remixes</strong>
          <span class="quick-card-copy">Playlist de remixes y edits publicados en YouTube.</span>
        </a>

        <a class="quick-card" href="/sets/">
          <span class="quick-card-kicker">Sesión larga</span>
          <strong>Sets</strong>
          <span class="quick-card-copy">Ya puedes escuchar un set largo dentro de la web.</span>
        </a>

        <a class="quick-card" href="/library/">
          <span class="quick-card-kicker">Producto digital</span>
          <strong>DJ Library</strong>
          <span class="quick-card-copy">Página lista para vender su librería de DJ dentro de la web.</span>
        </a>

        <a class="quick-card quick-card-primary" href="/booking/">
          <span class="quick-card-kicker">Contrataciones</span>
          <strong>Booking</strong>
          <span class="quick-card-copy">Cuéntame tu fecha y preparo la propuesta.</span>
        </a>
      </div>
    </section>

    <section class="hero" aria-label="Presentación principal">
      <div class="hero-grid">
        <div class="hero-media">
          <Image
            class="hero-photo"
            src={profileImage}
            alt="Marques Edition en cabina"
            loading="eager"
            sizes="(max-width: 959px) 100vw, 60vw"
          />
          <div class="hero-content">
            <div class="topline">
              <span class="eyebrow">Marques Edition</span>
              <span class="status-pill">DJ en Madrid</span>
            </div>

            <div class="actions">
              <div>
                <h1>Energía de club con identidad latina.</h1>
                <p class="lede">
                  Soy Marques Edition, DJ en Madrid crossover. Mezclo afro, latin, reggaeton y
                  open format para clubs, bodas y eventos privados donde la pista tiene que
                  responder de verdad.
                </p>
              </div>

              <div class="chips" aria-label="Estilo musical">
                <span class="chip">Afro</span>
                <span class="chip">Latin</span>
                <span class="chip">Reggaeton</span>
                <span class="chip">Crossover</span>
                <span class="chip">Open format</span>
                <span class="chip">Cabina en vivo</span>
                <span class="chip">Residente @pensionmimosas</span>
              </div>

              <div class="cta-row">
                <a class="cta" href="/booking/">Contrataciones ↗</a>
                <a class="cta-secondary" href="/about/">About ↗</a>
                <a class="cta-secondary" href="/reels/">Ver reels ↗</a>
                <a class="cta-secondary" href="/streams/">Ver remixes ↗</a>
                <a class="cta-secondary" href="/sets/">Escuchar set ↗</a>
                <a class="cta-secondary" href="/library/">Ver library ↗</a>
                <a class="cta-secondary" href="/media-links/">Media links ↗</a>
              </div>
            </div>
          </div>
        </div>

        <aside class="hero-panel" aria-label="Prueba social y latest reel">
          <p class="panel-kicker">Cabina abierta</p>
          <h2 class="panel-title">Aquí está todo lo que necesitas para entender cómo trabajo.</h2>
          <p class="panel-copy">
            Reels para ver cabina real, remixes para escuchar material propio y sets para escuchar
            sesiones largas dentro de la web, enlaces oficiales por un lado y una ruta de booking
            aparte para hablar conmigo sobre clubs, marcas, bodas y eventos privados.
          </p>

          <div class="stats" aria-label="Estadísticas">
            <div class="stat">
              <strong>{formatCompactNumber(profile.followers)}</strong>
              <span>Seguidores</span>
            </div>
            <div class="stat">
              <strong>{reels.length}</strong>
              <span>Reels</span>
            </div>
            <div class="stat">
              <strong>{streams.length}</strong>
              <span>Remixes</span>
            </div>
            <div class="stat">
              <strong>{publishedSets}</strong>
              <span>Sets</span>
            </div>
          </div>

          <div class="panel-divider"></div>

          <a
            class="latest-reel"
            href={latestReel.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Abrir el último reel: ${latestReel.title}`}
          >
            <p class="latest-label">Último reel</p>
            <p class="latest-title">{latestReel.title}</p>
            <p class="latest-meta">{formatShortSpanishDate(latestReel.date)} · {latestReel.label}</p>
          </a>
        </aside>
      </div>
    </section>

    <section class="events-home" aria-labelledby="events-home-title">
      <div class="events-home-copy">
        <p class="events-home-kicker">Próximas fechas</p>
        <h2 id="events-home-title">Dónde toco en los próximos eventos.</h2>
        <p class="events-home-desc">
          Una agenda clara por meses, al estilo de una página de tour: ciudad, venue y acceso
          directo a tickets o información de cada fecha.
        </p>
      </div>

      {
        residency && (
          <div class="residency-highlight">
            <div class="residency-highlight-copy">
              <p class="residency-label">Residencia fija</p>
              <strong>{residency.schedule_label}</strong>
              <span>{residency.venue} · {residency.time_label}</span>
              <span>{residency.address}</span>
            </div>

            <div class="residency-highlight-actions">
              <a class="quick-card-link" href="/events/">Ver agenda ↗</a>
              <a class="quick-card-link" href={residency.map_url} target="_blank" rel="noopener noreferrer">Cómo llegar ↗</a>
            </div>
          </div>
        )
      }

      <EventsBoard
        events={events}
        previewLimit={4}
        moreHref="/events/"
        emptyTitle="Todavía no hay fechas publicadas."
        emptyCopy="Dejo la sección lista para que las próximas actuaciones aparezcan aquí en cuanto carguemos el bloque de Bandsintown o el JSON manual."
      />
    </section>

    <section class="services" aria-label="Servicios">
      <article class="service-card service-card-wide">
        <h2>DJ en Madrid crossover para clubs, bodas y eventos privados</h2>
        <p>
          Si alguien busca un DJ en Madrid crossover, esta web deja clara la propuesta: una mezcla
          pensada para mover la pista con afro, latin, reggaeton, hits comerciales y cambios de
          energía medidos según el público.
        </p>
        <p>
          La base está en Madrid y la residencia en Pensión Mimosas refuerza una presencia real en
          cabina. La idea es adaptar el set con criterio a cada formato sin perder identidad.
        </p>
      </article>

      <article class="service-card">
        <h2>Clubs</h2>
        <p>
          Leo la pista, subo la tensión en el momento justo y mantengo la energía arriba durante
          toda la noche.
        </p>
      </article>
      <article class="service-card">
        <h2>Eventos privados</h2>
        <p>
          Adapto el set al espacio y al público sin perder mi identidad: afro, latin, reggaeton y
          crossover con criterio.
        </p>
      </article>
      <article class="service-card">
        <h2>Bodas</h2>
        <p>
          Construyo sesiones para invitados distintos, cambios de ritmo y una pista conectada desde
          el primer tema hasta el cierre.
        </p>
      </article>
    </section>

    <Footer />
  </main>

  <style>
    .page {
      width: min(100%, 1180px);
      margin: 0 auto;
    }

    .quick-nav {
      margin-bottom: 1.1rem;
      padding: 1.05rem 1.05rem 1.1rem;
      border-radius: 28px;
      border: 1px solid rgba(171, 141, 255, 0.16);
      background:
        radial-gradient(420px 220px at 12% 10%, rgba(255, 90, 191, 0.1), transparent 68%),
        radial-gradient(380px 220px at 88% 16%, rgba(69, 215, 255, 0.08), transparent 70%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
        linear-gradient(160deg, rgba(90, 70, 180, 0.1), rgba(18, 12, 50, 0.12));
    }

    .quick-nav-copy {
      max-width: 38rem;
    }

    .quick-nav-kicker {
      margin: 0;
      color: #45d7ff;
      font-size: 0.74rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .quick-nav h2 {
      margin: 0.4rem 0 0;
      font-size: 1.18rem;
      line-height: 1.25;
    }

    .quick-nav-grid {
      margin-top: 1rem;
      display: grid;
      gap: 0.8rem;
    }

    .quick-card {
      display: grid;
      gap: 0.38rem;
      padding: 1.05rem;
      border-radius: 22px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.05);
      color: #fff;
      text-decoration: none;
      transition:
        transform 160ms ease,
        border-color 160ms ease,
        background 160ms ease,
        box-shadow 160ms ease;
    }

    .quick-card:hover,
    .quick-card:focus-visible {
      transform: translateY(-2px);
      border-color: rgba(69, 215, 255, 0.28);
      background: rgba(255, 255, 255, 0.08);
      box-shadow: 0 14px 30px rgba(5, 2, 20, 0.3);
      outline: none;
    }

    .quick-card-primary {
      background:
        linear-gradient(135deg, rgba(255, 90, 191, 0.16), rgba(69, 215, 255, 0.12)),
        rgba(255, 255, 255, 0.05);
    }

    .quick-card-kicker {
      color: #45d7ff;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .quick-card strong {
      font-size: 1.08rem;
      line-height: 1.16;
    }

    .quick-card-copy {
      color: #dde4f7;
      font-size: 0.88rem;
      line-height: 1.5;
    }

    .hero {
      position: relative;
      overflow: hidden;
      border-radius: 34px;
      border: 1px solid rgba(171, 141, 255, 0.2);
      background:
        radial-gradient(520px 320px at 18% 10%, rgba(255, 90, 191, 0.12), transparent 64%),
        radial-gradient(540px 340px at 82% 12%, rgba(69, 215, 255, 0.12), transparent 66%),
        linear-gradient(180deg, rgba(28, 18, 70, 0.9), rgba(14, 9, 38, 0.98));
      box-shadow: 0 28px 72px rgba(2, 0, 12, 0.56);
      padding: 1.05rem;
    }

    .hero-grid {
      display: grid;
      gap: 1.05rem;
    }

    .hero-media,
    .hero-panel {
      min-width: 0;
    }

    .hero-media {
      min-height: 740px;
      border-radius: 28px;
      overflow: hidden;
      position: relative;
      background: rgba(7, 4, 18, 0.2);
    }

    .hero-photo {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 24%;
    }

    .hero-content {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      padding: 1.15rem 1.15rem 1.35rem;
      background:
        radial-gradient(420px 220px at 12% 10%, rgba(255, 90, 191, 0.18), transparent 68%),
        radial-gradient(360px 220px at 88% 18%, rgba(69, 215, 255, 0.16), transparent 70%),
        linear-gradient(180deg, rgba(6, 3, 17, 0.18), rgba(6, 3, 17, 0.78));
    }

    .topline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.8rem;
      flex-wrap: wrap;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #45d7ff;
    }

    .status-pill,
    .chip {
      display: inline-flex;
      align-items: center;
      min-height: 36px;
      padding: 0.55rem 0.85rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(6, 3, 17, 0.5);
      color: #fff;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.03em;
      backdrop-filter: blur(14px);
    }

    .actions {
      display: grid;
      gap: 1rem;
      margin-top: auto;
    }

    h1 {
      margin: 0;
      max-width: 8.5ch;
      font-size: clamp(2.15rem, 7.6vw, 4.7rem);
      line-height: 0.92;
    }

    .lede {
      max-width: 32rem;
      margin: 0.8rem 0 0;
      color: #f0f4ff;
      font-size: 0.96rem;
      line-height: 1.6;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      align-items: flex-start;
    }

    .cta-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 0.7rem;
      align-items: stretch;
    }

    .cta,
    .cta-secondary {
      min-height: 50px;
      padding: 0.92rem 1rem;
      border-radius: 16px;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 900;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 0;
      text-align: center;
    }

    .cta {
      color: #160b34;
      background: linear-gradient(135deg, rgba(255, 90, 191, 0.96), rgba(69, 215, 255, 0.9));
    }

    .cta-secondary {
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.06);
    }

    .hero-panel {
      padding: 1.1rem;
      border-radius: 28px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
        linear-gradient(160deg, rgba(90, 70, 180, 0.12), rgba(18, 12, 50, 0.16));
    }

    .panel-kicker {
      margin: 0;
      color: #45d7ff;
      font-size: 0.74rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .panel-title {
      margin: 0.4rem 0 0;
      font-size: 1.15rem;
      line-height: 1.28;
    }

    .panel-copy {
      margin: 0.55rem 0 0;
      color: #dde4f7;
      font-size: 0.9rem;
      line-height: 1.58;
    }

    .stats {
      margin-top: 1rem;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 0.7rem;
    }

    .stat {
      padding: 0.82rem;
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.05);
    }

    .stat strong {
      display: block;
      font-size: 1rem;
    }

    .stat span {
      display: block;
      margin-top: 0.22rem;
      color: #bec8e3;
      font-size: 0.76rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    .panel-divider {
      height: 1px;
      margin: 0.95rem 0;
      background: rgba(255, 255, 255, 0.08);
    }

    .latest-reel {
      display: block;
      padding: 0.2rem 0;
      color: inherit;
      text-decoration: none;
      border-radius: 16px;
      transition:
        transform 160ms ease,
        color 160ms ease,
        opacity 160ms ease;
    }

    .latest-reel:hover,
    .latest-reel:focus-visible {
      transform: translateY(-1px);
      opacity: 0.96;
      outline: none;
    }

    .latest-reel:hover .latest-title,
    .latest-reel:focus-visible .latest-title {
      color: #fff;
      text-decoration: underline;
      text-decoration-color: rgba(69, 215, 255, 0.6);
      text-underline-offset: 0.16em;
    }

    .latest-label,
    .latest-title,
    .latest-meta {
      margin: 0;
    }

    .latest-label {
      color: #45d7ff;
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .latest-title {
      margin-top: 0.45rem;
      font-size: 1rem;
      line-height: 1.4;
    }

    .latest-meta {
      margin-top: 0.35rem;
      color: #c2cae2;
      font-size: 0.82rem;
      font-weight: 700;
    }

    .services {
      margin-top: 1.1rem;
      display: grid;
      gap: 0.95rem;
    }

    .events-home {
      margin-top: 1.1rem;
      padding: 1.1rem;
      border-radius: 28px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
        linear-gradient(160deg, rgba(90, 70, 180, 0.12), rgba(18, 12, 50, 0.16));
    }

    .events-home-copy {
      max-width: 42rem;
      margin-bottom: 1rem;
    }

    .residency-highlight {
      margin-bottom: 1rem;
      padding: 1.05rem;
      border-radius: 22px;
      border: 1px solid rgba(69, 215, 255, 0.18);
      background:
        radial-gradient(380px 180px at 12% 8%, rgba(69, 215, 255, 0.12), transparent 72%),
        radial-gradient(320px 180px at 88% 12%, rgba(255, 90, 191, 0.12), transparent 74%),
        linear-gradient(155deg, rgba(34, 67, 118, 0.32), rgba(16, 11, 38, 0.62));
    }

    .residency-highlight-copy {
      display: grid;
      gap: 0.3rem;
    }

    .residency-label {
      margin: 0;
      color: #45d7ff;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .residency-highlight strong {
      font-size: 1rem;
      line-height: 1.3;
    }

    .residency-highlight span {
      color: #dbe5fd;
      font-size: 0.86rem;
      line-height: 1.45;
    }

    .residency-highlight-actions {
      margin-top: 1rem;
      display: grid;
      gap: 0.65rem;
    }

    .quick-card-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      padding: 0.6rem 0.95rem;
      border-radius: 999px;
      border: 1px solid rgba(69, 215, 255, 0.28);
      background: rgba(69, 215, 255, 0.08);
      color: #fff;
      font-size: 0.82rem;
      font-weight: 800;
      text-decoration: none;
    }

    .events-home-kicker {
      margin: 0;
      color: #45d7ff;
      font-size: 0.74rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .events-home h2 {
      margin: 0.42rem 0 0;
      font-size: 1.18rem;
      line-height: 1.25;
    }

    .events-home-desc {
      margin: 0.55rem 0 0;
      color: #dde4f7;
      font-size: 0.9rem;
      line-height: 1.58;
    }

    .service-card {
      padding: 1.1rem;
      border-radius: 24px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
        linear-gradient(160deg, rgba(90, 70, 180, 0.12), rgba(18, 12, 50, 0.16));
    }

    .service-card h2 {
      margin: 0;
      font-size: 1.05rem;
      line-height: 1.28;
    }

    .service-card p {
      margin: 0.5rem 0 0;
      color: #dde4f7;
      font-size: 0.9rem;
      line-height: 1.58;
    }

    .service-card-wide {
      grid-column: 1 / -1;
    }

    @media (min-width: 900px) {
      .quick-nav {
        padding: 1.15rem 1.25rem 1.2rem;
      }

      .quick-nav-grid {
        grid-template-columns: repeat(5, minmax(0, 1fr));
      }

      .quick-card {
        min-height: 132px;
        align-content: start;
      }

      .hero {
        padding: 1.2rem;
      }

      .hero-grid {
        grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.72fr);
      }

      .hero-media {
        min-height: 720px;
      }

      .hero-content {
        padding: 1.35rem 1.35rem 1.5rem;
      }

      h1 {
