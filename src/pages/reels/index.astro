---
import SiteLayout from "../../layouts/SiteLayout.astro";
import InnerPage from "../../components/layout/InnerPage.astro";
import Footer from "../../components/layout/Footer.astro";
import ReelCard from "../../components/content/ReelCard.astro";
import { getInnerPageNav } from "../../config/navigation";
import { getReelsData } from "../../lib/content";
import { formatShortSpanishDate } from "../../lib/format";

const navItems = getInnerPageNav("/reels/");

const { reels, profile, generatedAt } = await getReelsData();
const latestReel = reels[0];
const featuredReels = reels.slice(1, 5);
const extraReels = reels.slice(5);

const formatUpdated = generatedAt ? formatShortSpanishDate(new Date(generatedAt)) : "";
---

<SiteLayout
  title="Marques Edition | Reels"
  description="Una selección de reels de Marques Edition en cabina. Clubs, bodas, residencia y momentos reales de pista."
>
  <InnerPage
    ariaLabel="Reels de Marques Edition"
    eyebrow="Reels"
    title="Aquí puedes ver cómo se vive una sesión conmigo en cabina."
    description="He reunido algunos reels de clubs, bodas y noches en Pensión Mimosas para que se entienda rápido mi forma de pinchar, leer la pista y mover una sala."
    navItems={navItems}
  >
    <Fragment slot="main">
      <section class="section hero-reel" aria-labelledby="hero-reel-title">
        <p class="section-kicker">Reel destacado</p>
        <h2 id="hero-reel-title">Un vistazo rápido a cómo se siente una noche en cabina</h2>
        <p class="section-copy">
          Si quiere entender rápido el tipo de energía que llevo a una sala, empiece por aquí. Es
          una muestra corta, pero bastante fiel, del ambiente que busco cuando la pista ya está
          arriba.
        </p>

        <div class="hero-reel-grid">
          <a class="hero-media" href={latestReel.url} target="_blank" rel="noopener noreferrer">
            <img class="hero-media-bg" src={latestReel.thumbnail_url} alt="" loading="eager" decoding="async" aria-hidden="true" />
            <img class="hero-media-image" src={latestReel.thumbnail_url} alt={`Miniatura del reel ${latestReel.title}`} loading="eager" decoding="async" />
            <span class="hero-media-badge">Ver reel ↗</span>
          </a>

          <div class="hero-copy">
            <div class="hero-chip-row" aria-label="Resumen del reel">
              <span class="hero-chip">Último reel</span>
              <span class="hero-chip">{formatShortSpanishDate(latestReel.date)}</span>
              <span class="hero-chip">{latestReel.label}</span>
            </div>

            <h3 class="hero-title">{latestReel.title}</h3>
            <p class="hero-text">{latestReel.summary}</p>

            <div class="hero-stats" aria-label="Resumen del perfil">
              <span class="hero-stat">{profile.followers} seguidores</span>
              <span class="hero-stat">{reels.length} reels</span>
              <span class="hero-stat">Afro / Latin / Open format</span>
            </div>

            <div class="hero-actions">
              <a class="hero-link hero-link--primary" href="/booking/">Hablar de booking ↗</a>
              <a class="hero-link" href="https://www.instagram.com/marquesedition/reels/" target="_blank" rel="noopener noreferrer">Abrir reels en Instagram ↗</a>
            </div>
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="reels-title">
        <p class="section-kicker">Más reels</p>
        <h2 id="reels-title">Más momentos recientes</h2>
        <p class="section-copy">
          Aquí puede ver más situaciones reales: residencia, clubs, bodas y cambios de energía en
          distintos contextos.
        </p>

        <div class="reels">
          {featuredReels.map((reel, index) => <ReelCard reel={reel} index={index + 2} />)}
        </div>

        {
          extraReels.length > 0 && (
            <details class="reels-more" id="reels-more">
              <summary class="reels-toggle">Ver más reels ({reels.length})</summary>
              <div class="reels">
                {extraReels.map((reel, index) => <ReelCard reel={reel} index={index + 6} />)}
              </div>
            </details>
          )
        }
      </section>
    </Fragment>

    <Fragment slot="sidebar">
      <section class="side-card" aria-labelledby="summary-title">
        <p class="side-kicker">Resumen</p>
        <h2 id="summary-title">Si le encaja esta línea, siga por aquí</h2>
        <p>
          Esta página está pensada para enseñar cabina y ambiente. Si quiere escuchar más material
          o hablar de una fecha, estas son las rutas más útiles.
        </p>

        <div class="facts" aria-label="Dónde encaja mejor">
          <div class="fact">
            <strong>Encaje</strong>
            <span>Clubs, privados, bodas y residencia</span>
          </div>
          <div class="fact">
            <strong>Sonido</strong>
            <span>Afro, latin, reggaetón y open format</span>
          </div>
        </div>

        <div class="side-stack">
          <a class="side-link side-link--primary" href="/booking/">Hablar de booking ↗</a>
          <a class="side-link" href="/streams/">Escuchar remixes ↗</a>
          <a class="side-link" href="/sets/">Escuchar sets ↗</a>
          <a class="side-link" href="/events/">Ver agenda ↗</a>
          <a class="side-link" href="https://www.instagram.com/marquesedition/reels/" target="_blank" rel="noopener noreferrer">Abrir reels en Instagram ↗</a>
        </div>
      </section>
    </Fragment>

    <Footer slot="footer" />
  </InnerPage>

      <p class="status-copy">
    {reels.length} reels · actualizado {formatUpdated} ·
    <a href="https://www.instagram.com/marquesedition/reels/" target="_blank" rel="noopener noreferrer">abrir perfil ↗</a>
  </p>
  <style>
    .hero-reel {
      overflow: hidden;
    }

    .hero-reel-grid {
      margin-top: 1rem;
      display: grid;
      gap: 0.95rem;
    }

    .hero-media {
      position: relative;
      display: grid;
      place-items: center;
      min-width: 0;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      border-radius: 22px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background:
        radial-gradient(260px 180px at 18% 12%, rgba(255, 90, 191, 0.18), transparent 72%),
        radial-gradient(260px 180px at 82% 10%, rgba(69, 215, 255, 0.14), transparent 74%),
        rgba(7, 4, 19, 0.9);
      text-decoration: none;
    }

    .hero-media-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: blur(26px) saturate(1.05);
      transform: scale(1.08);
      opacity: 0.38;
    }

    .hero-media-image {
      position: relative;
      z-index: 1;
      width: calc(100% - 1rem);
      height: calc(100% - 1rem);
      object-fit: cover;
      border-radius: 18px;
      box-shadow: 0 20px 40px rgba(5, 2, 20, 0.32);
    }

    .hero-media-badge {
      position: absolute;
      right: 0.85rem;
      bottom: 0.85rem;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 38px;
      padding: 0.55rem 0.82rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: rgba(8, 5, 22, 0.72);
      color: #fff;
      font-size: 0.78rem;
      font-weight: 800;
      backdrop-filter: blur(12px);
    }

    .hero-copy {
      display: grid;
      align-content: start;
      gap: 0.85rem;
    }

    .hero-chip-row,
    .hero-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
    }

    .hero-chip,
    .hero-stat,
    .reels {
      margin-top: 0.9rem;
    }

    .hero-chip,
    .hero-stat,
    .stat {
      min-height: 38px;
      padding: 0.6rem 0.86rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.06);
      color: #fff;
      font-size: 0.8rem;
      font-weight: 800;
    }

    .hero-chip {
      min-height: 34px;
      padding: 0.45rem 0.74rem;
      font-size: 0.75rem;
    }

    .hero-title {
      margin: 0;
      font-size: 1.18rem;
      line-height: 1.24;
    }

    .hero-text {
      margin: 0;
      color: var(--muted-strong);
      font-size: 0.92rem;
      line-height: 1.62;
    }

    .hero-actions {
      display: grid;
      gap: 0.65rem;
    }

    .hero-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      padding: 0.7rem 1rem;
      border-radius: 999px;
      border: 1px solid rgba(69, 215, 255, 0.28);
      background: rgba(69, 215, 255, 0.08);
      color: var(--blue);
      font-size: 0.84rem;
      font-weight: 800;
      text-decoration: none;
    }

    .hero-link--primary,
    .side-link--primary {
      color: #160b34;
      border-color: transparent;
      background: linear-gradient(135deg, rgba(255, 90, 191, 0.96), rgba(69, 215, 255, 0.9));
    }

    .reels {
      display: grid;
      gap: 0.85rem;
    }

    @media (min-width: 960px) {
      .hero-reel-grid {
        grid-template-columns: minmax(300px, 0.92fr) minmax(0, 1fr);
        align-items: start;
      }

      .reels {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        align-items: start;
      }
    }

    .fact {
      padding: 0.95rem;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.05);
    }

    .fact strong {
      display: block;
      font-size: 0.95rem;
    }

    .fact span {
      display: block;
      margin-top: 0.24rem;
      color: var(--muted-strong);
      font-size: 0.82rem;
      line-height: 1.45;
    }

    .side-stack,
    .facts {
      display: grid;
      gap: 0.65rem;
    }

    .side-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 0.55rem 0.9rem;
      border-radius: 999px;
      border: 1px solid rgba(69, 215, 255, 0.28);
      background: rgba(69, 215, 255, 0.08);
      color: var(--blue);
      font-size: 0.82rem;
      font-weight: 800;
      text-decoration: none;
    }

    .reels-more {
      margin-top: 0.95rem;
    }

    .reels-toggle {
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 54px;
      padding: 0.9rem 1rem;
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
        linear-gradient(155deg, rgba(36, 24, 85, 0.54), rgba(18, 12, 44, 0.78));
      color: #f7f3ff;
      font-size: 0.9rem;
      font-weight: 800;
      cursor: pointer;
    }

    .reels-toggle::-webkit-details-marker {
      display: none;
    }

    .status-copy {
      width: min(100%, 1180px);
      margin: 0.9rem auto 0;
      color: var(--muted-strong);
      font-size: 0.88rem;
      line-height: 1.55;
      text-align: center;
    }

    .status-copy a {
      color: #dfe8ff;
      text-decoration: none;
    }

    @media (max-width: 560px) {
      .hero-media {
        border-radius: 18px;
      }

      .hero-media-image {
        width: calc(100% - 0.7rem);
        height: calc(100% - 0.7rem);
        border-radius: 14px;
      }
    }
  </style>
</SiteLayout>
