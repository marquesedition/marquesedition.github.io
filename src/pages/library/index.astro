---
import SiteLayout from "../../layouts/SiteLayout.astro";
import InnerPage from "../../components/layout/InnerPage.astro";
import Footer from "../../components/layout/Footer.astro";
import { getInnerPageNav } from "../../config/navigation";

const navItems = getInnerPageNav("/library/");
const libraryTitle = "Marques Edition DJ Library";
const checkoutUrl =
  "mailto:bookings@marquesedition.com?subject=Quiero%20comprar%20la%20DJ%20Library";
const supportUrl = "/booking/";
const librarySchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: libraryTitle,
  category: "Digital music library",
  brand: {
    "@type": "Brand",
    name: "Marques Edition",
  },
  description:
    "Librería digital para DJs con edits, herramientas de pista, remixes y material listo para clubs, bodas y eventos privados.",
  url: "https://www.marquesedition.com/library/",
};
---

<SiteLayout
  title="Marques Edition | DJ Library"
  description="Página de venta de la librería DJ de Marques Edition. Edits, remixes y herramientas de pista listas para cabina."
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(librarySchema)} />
  </Fragment>

  <InnerPage
    ariaLabel="DJ Library de Marques Edition"
    eyebrow="Library"
    title="Mi librería DJ ya tiene una página lista para vender."
    description="Aquí irá toda la parte comercial de la librería: qué incluye, para quién está pensada, cómo se entrega y el acceso directo para comprarla."
    navItems={navItems}
  >
    <Fragment slot="main">
      <div class="chip-row" aria-label="Resumen de la librería">
        <span class="chip">Edits</span>
        <span class="chip">Remixes</span>
        <span class="chip">Herramientas de pista</span>
        <span class="chip">Club / bodas / privados</span>
        <span class="chip">Acceso digital</span>
      </div>

      <section class="section library-hero" aria-labelledby="library-hero-title">
        <p class="section-kicker">Producto digital</p>
        <h2 id="library-hero-title">{libraryTitle}</h2>
        <p class="section-copy">
          Esta página está pensada para vender su librería de DJ con una propuesta clara y sin
          ruido. El foco está en enseñar el valor real del material: edits útiles, remixes para la
          pista y herramientas de mezcla listas para sonar en cabina.
        </p>

        <div class="library-panel">
          <div class="library-copy">
            <strong>Qué va a encontrar quien entre aquí</strong>
            <p>
              Material práctico para DJs que quieren ahorrar tiempo, subir el nivel de sus sets y
              tener recursos que funcionen en clubs, bodas y eventos privados.
            </p>
          </div>

          <div class="library-actions">
            <a class="cta-primary" href={checkoutUrl}>Comprar la librería ↗</a>
            <a class="cta-secondary" href={supportUrl}>Hacer una consulta ↗</a>
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="includes-title">
        <p class="section-kicker">Contenido</p>
        <h2 id="includes-title">Qué puede incluir la librería</h2>
        <div class="feature-grid" aria-label="Qué incluye la librería">
          <article class="feature-card">
            <strong>Edits listos para pinchar</strong>
            <span>Versiones pensadas para entrar rápido, mezclar mejor y sostener la energía.</span>
          </article>
          <article class="feature-card">
            <strong>Remixes propios</strong>
            <span>Material con su identidad, útil para diferenciar el set y no sonar genérico.</span>
          </article>
          <article class="feature-card">
            <strong>Intro edits / outro edits</strong>
            <span>Recursos pensados para cabinas reales, cambios de bloque y entradas limpias.</span>
          </article>
          <article class="feature-card">
            <strong>Herramientas de pista</strong>
            <span>Transiciones, cortes, boosts de energía y material útil para momentos clave.</span>
          </article>
          <article class="feature-card">
            <strong>Selección pensada para Madrid</strong>
            <span>Enfoque realista para público mixto, cabina latina, open format y eventos.</span>
          </article>
          <article class="feature-card">
            <strong>Entrega digital inmediata</strong>
            <span>Página ya preparada para conectarse a un checkout y a un acceso de descarga.</span>
          </article>
        </div>
      </section>

      <section class="section" aria-labelledby="fit-title">
        <p class="section-kicker">Para quién es</p>
        <h2 id="fit-title">Una librería pensada para DJs que trabajan de verdad la pista</h2>
        <p class="section-copy">
          No está enfocada a coleccionar archivos por tener más carpetas, sino a tener menos
          fricción en cabina y más recursos que ayuden a mantener el set arriba.
        </p>

        <div class="fit-grid" aria-label="Tipos de DJ">
          <div class="fit-card">
            <strong>DJ de club</strong>
            <span>Para quien necesita edits ágiles, cambios de energía y material con pegada.</span>
          </div>
          <div class="fit-card">
            <strong>DJ de bodas</strong>
            <span>Para quien mezcla públicos distintos y necesita transiciones más limpias.</span>
          </div>
          <div class="fit-card">
            <strong>DJ open format</strong>
            <span>Para quien quiere herramientas flexibles sin perder color ni personalidad.</span>
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="delivery-title">
        <p class="section-kicker">Compra y entrega</p>
        <h2 id="delivery-title">Cómo queda montado el flujo de compra</h2>
        <div class="delivery-steps" aria-label="Flujo de compra">
          <div class="delivery-step">
            <strong>1. El usuario entra en esta página</strong>
            <span>Ve el producto, entiende el valor y tiene un CTA de compra claro.</span>
          </div>
          <div class="delivery-step">
            <strong>2. Pulsa en comprar</strong>
            <span>
              El botón ya está preparado para conectarse a su pasarela favorita con un solo enlace.
            </span>
          </div>
          <div class="delivery-step">
            <strong>3. Recibe acceso al material</strong>
            <span>
              Después del pago, puede llevar a descarga directa, carpeta privada o plataforma
              externa según cómo quiera venderla.
            </span>
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="faq-title">
        <p class="section-kicker">FAQ</p>
        <h2 id="faq-title">Preguntas que ayudan a vender mejor</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>¿Qué formato tendrá la librería?</summary>
            <p>La página está preparada para vender packs digitales descargables por enlace o carpeta privada.</p>
          </details>
          <details class="faq-item">
            <summary>¿Se puede actualizar con nuevos archivos?</summary>
            <p>Sí. La estructura admite versiones futuras, bonus packs o acceso renovable sin rehacer la página.</p>
          </details>
          <details class="faq-item">
            <summary>¿Se puede conectar a Gumroad, Stripe o Payhip?</summary>
            <p>Sí. Solo hay que sustituir el enlace del botón principal por el checkout que quiera usar.</p>
          </details>
        </div>
      </section>
    </Fragment>

    <Fragment slot="sidebar">
      <section class="side-card" aria-labelledby="status-title">
        <p class="side-kicker">Estado</p>
        <h2 id="status-title">Página lista para activar la venta</h2>
        <p>
          La estructura comercial ya está montada. Lo único que falta para tener compra automática
          es su enlace final de checkout.
        </p>

        <div class="facts" aria-label="Estado de la venta">
          <span class="fact-chip">Página de venta creada</span>
          <span class="fact-chip">CTA de compra visible</span>
          <span class="fact-chip">Flujo de entrega definido</span>
          <span class="fact-chip">Checkout enchufable</span>
        </div>
      </section>

      <section class="side-card" aria-labelledby="next-title">
        <p class="side-kicker">Siguiente paso</p>
        <h2 id="next-title">Lo que falta para cerrar la venta real</h2>
        <p>
          Cuando tenga el enlace de pago, se cambia una sola URL y la página queda lista para
          vender de forma directa.
        </p>

        <div class="side-stack">
          <a class="side-link side-link--primary" href={checkoutUrl}>Comprar la librería ↗</a>
          <a class="side-link" href={supportUrl}>Hablar de la librería ↗</a>
          <a class="side-link" href="/media-links/">Ver media links ↗</a>
        </div>
      </section>
    </Fragment>

    <Footer slot="footer" />
  </InnerPage>

  <style>
    .library-panel,
    .feature-grid,
    .fit-grid,
    .delivery-steps,
    .faq-list,
    .library-actions,
    .side-stack {
      display: grid;
      gap: 0.75rem;
    }

    .library-panel,
    .feature-card,
    .fit-card,
    .delivery-step {
      padding: 0.98rem;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.05);
    }

    .library-panel {
      margin-top: 0.95rem;
      gap: 0.95rem;
    }

    .library-copy strong,
    .feature-card strong,
    .fit-card strong,
    .delivery-step strong {
      display: block;
      font-size: 0.95rem;
      line-height: 1.28;
    }

    .library-copy p,
    .feature-card span,
    .fit-card span,
    .delivery-step span {
      display: block;
      margin-top: 0.28rem;
      color: var(--muted-strong);
      font-size: 0.84rem;
      line-height: 1.5;
    }

    .cta-primary,
    .cta-secondary,
    .side-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 0.78rem 1rem;
      border-radius: 999px;
      text-decoration: none;
      font-size: 0.84rem;
      font-weight: 900;
      text-align: center;
    }

    .cta-primary,
    .side-link--primary {
      color: #160b34;
      background: linear-gradient(135deg, rgba(255, 90, 191, 0.96), rgba(69, 215, 255, 0.9));
    }

    .cta-secondary,
    .side-link {
      border: 1px solid rgba(69, 215, 255, 0.28);
      background: rgba(69, 215, 255, 0.08);
      color: var(--blue);
    }

    .faq-item {
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.04);
      overflow: hidden;
    }

    .faq-item summary {
      cursor: pointer;
      list-style: none;
      padding: 1rem;
      font-size: 0.92rem;
      font-weight: 800;
    }

    .faq-item summary::-webkit-details-marker {
      display: none;
    }

    .faq-item p {
      margin: 0;
      padding: 0 1rem 1rem;
      color: var(--muted-strong);
      font-size: 0.84rem;
      line-height: 1.55;
    }

    @media (min-width: 820px) {
      .feature-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .fit-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .library-actions {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
  </style>
</SiteLayout>
