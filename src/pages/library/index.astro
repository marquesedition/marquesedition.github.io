---
import SiteLayout from "../../layouts/SiteLayout.astro";
import InnerPage from "../../components/layout/InnerPage.astro";
import Footer from "../../components/layout/Footer.astro";
import { getInnerPageNav } from "../../config/navigation";
import { formatShortSpanishDate } from "../../lib/format";
import libraryData from "../../data/library.json";

const navItems = getInnerPageNav("/library/");
const library = libraryData.library;
const stats = libraryData.stats;
const generatedAt = libraryData.generated_at
  ? formatShortSpanishDate(new Date(libraryData.generated_at))
  : "";
const previewTracks = Number(stats.preview_tracks ?? 0);
const previewSeconds = Number(stats.preview_seconds ?? 60);
const sourceUrl = libraryData.source_url;
const supportUrl = "/booking/";
const catalogEndpoint = "/media-links/library.json";

const featuredCrates = [...(library.folders ?? [])]
  .sort((a, b) => b.track_count - a.track_count)
  .slice(0, 5)
  .map((folder, index) => ({
    rank: index + 1,
    name: folder.name,
    trackCount: folder.track_count,
    folderCount: folder.folder_count,
    sizeLabel: folder.total_size_label,
  }));

const programRows = [
  {
    label: "Peak Latin",
    detail: "Latin Urban, Pachanga, Tropical y edits para franjas de máxima energía.",
  },
  {
    label: "Open Format",
    detail: "Cumbias, throwbacks y bloques mixtos para eventos largos y públicos variados.",
  },
  {
    label: "Club Utility",
    detail: "Acapellas, intros, clean edits y herramientas rápidas para mezclar con intención.",
  },
];

const summaryChips = [
  `${stats.tracks} tracks`,
  `${stats.folders} carpetas`,
  `${previewSeconds / 60} min preview`,
  `${previewTracks} previews listos`,
  stats.total_size_label || "",
].filter(Boolean);

const librarySchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${library.name} | DJ Library`,
  description:
    "Recordpool digital de Marques Edition con búsqueda rápida, navegación ligera y previews locales protegidos.",
  url: "https://www.marquesedition.com/library/",
};
---

<SiteLayout
  title="Marques Edition | Recordpool"
  description="Recordpool digital de Marques Edition con navegación rápida, categorías por crate y previews locales protegidos de 1 minuto."
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(librarySchema)} />
  </Fragment>

  <InnerPage
    ariaLabel="Recordpool de Marques Edition"
    eyebrow="Recordpool"
    title="Recordpool privado con lenguaje de club."
    description="Crates prioritarios, búsqueda inmediata y previews de 60 segundos pensados para descubrir música sin comprometer el archivo original."
    navItems={navItems}
  >
    <Fragment slot="main">
      <section class="section stage" aria-labelledby="recordpool-title">
        <div class="chip-row chip-row--ticker" aria-label="Resumen del recordpool">
          {summaryChips.map((chip) => <span class="chip">{chip}</span>)}
        </div>

        <div class="stage-grid">
          <div class="stage-copy">
            <p class="section-kicker">Marques Edition recordpool</p>
            <h2 id="recordpool-title">Selección rápida, browsing limpio y preview protegido.</h2>
            <p class="section-copy">
              La library deja de parecer un listado improvisado y pasa a sentirse como una
              herramienta de trabajo: crates fuertes arriba, contexto editorial y un browser denso
              para escuchar sin fricción.
            </p>

            <div class="hero-actions">
              <a class="cta-primary" href={sourceUrl} target="_blank" rel="noopener noreferrer">
                Abrir carpeta en Drive ↗
              </a>
              <a class="cta-secondary" href={supportUrl}>Solicitar acceso / consulta ↗</a>
            </div>
          </div>

          <div class="stage-dashboard" aria-label="Panel del recordpool">
            <article class="stage-stat">
              <span class="stage-stat__label">Coverage</span>
              <strong>{previewTracks}</strong>
              <span class="stage-stat__caption">tracks con preview activo</span>
              <p>
                {stats.folders} carpetas ordenadas y {stats.total_size_label} de librería fuente
                sincronizada.
              </p>
            </article>

            <article class="stage-panel">
              <p class="feature-kicker">Top crates</p>
              <h3>Lo que más pesa en el catálogo</h3>
              <div class="crate-stack">
                {featuredCrates.slice(0, 3).map((crate) => (
                  <article class="crate-strip">
                    <span class="crate-rank">0{crate.rank}</span>
                    <div>
                      <strong>{crate.name}</strong>
                      <span>
                        {crate.trackCount} tracks
                        {crate.folderCount > 0 ? ` · ${crate.folderCount} subcarpetas` : ""}
                      </span>
                    </div>
                  </article>
                ))}
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="section editorial-board" aria-labelledby="editorial-title">
        <p class="section-kicker">Selección</p>
        <h2 id="editorial-title">Portada editorial arriba, browser técnico debajo</h2>
        <p class="section-copy">
          El objetivo es que la parte superior venda nivel y que el listado inferior sirva para
          trabajar. Menos tarjeta genérica, más sensación de producto serio.
        </p>

        <div class="editorial-grid">
          <section class="feature-card feature-card--lead" aria-labelledby="featured-crates-title">
            <p class="feature-kicker">Crates destacados</p>
            <h3 id="featured-crates-title">Bloques con mayor volumen</h3>
            <div class="crate-grid">
              {featuredCrates.map((crate) => (
                <article class="crate-card">
                  <span class="crate-rank">0{crate.rank}</span>
                  <strong>{crate.name}</strong>
                  <span>
                    {crate.trackCount} tracks
                    {crate.folderCount > 0 ? ` · ${crate.folderCount} subcarpetas` : ""}
                  </span>
                  {crate.sizeLabel && <em>{crate.sizeLabel}</em>}
                </article>
              ))}
            </div>
          </section>

          <section class="feature-card" aria-labelledby="program-title">
            <p class="feature-kicker">Programación</p>
            <h3 id="program-title">Tres rutas para leer la pista</h3>
            <div class="program-list">
              {programRows.map((row) => (
                <article class="program-card">
                  <strong>{row.label}</strong>
                  <span>{row.detail}</span>
                </article>
              ))}
            </div>
          </section>

          <section class="feature-card feature-card--utility" aria-labelledby="protection-title">
            <p class="feature-kicker">Protección</p>
            <h3 id="protection-title">Qué protege la web y qué deja ver</h3>
            <div class="utility-list">
              <article class="utility-row">
                <strong>Preview de 1 minuto</strong>
                <span>Tiempo suficiente para valorar groove, arreglo y energía sin liberar el tema.</span>
              </article>
              <article class="utility-row">
                <strong>Compresión agresiva</strong>
                <span>Mono, bitrate bajo y tamaño ligero para servir rápido y proteger mejor.</span>
              </article>
              <article class="utility-row">
                <strong>Drive como fuente</strong>
                <span>La organización original sigue intacta; la web solo gestiona la escucha.</span>
              </article>
            </div>
          </section>
        </div>
      </section>

      <section class="section catalog-section" aria-labelledby="browser-title">
        <p class="section-kicker">Browser</p>
        <h2 id="browser-title">Buscar, filtrar y escuchar como en un recordpool real</h2>
        <p class="section-copy">
          Aquí manda la velocidad. El catálogo vive en JSON, el resultado se pinta bajo demanda y
          cada fila concentra lo justo: identidad, tags, preview y acceso al archivo fuente.
        </p>

        <div class="recordpool-shell" id="recordpool-app" data-endpoint={catalogEndpoint}>
          <div class="catalog-topline">
            <div>
              <p class="feature-kicker">Search / cue / move</p>
              <h3>Navegador rápido de pistas</h3>
            </div>

            <div class="catalog-topline__facts">
              <span class="fact-chip">{previewSeconds / 60} min preview</span>
              <span class="fact-chip">JSON catalog</span>
              <span class="fact-chip">compact DJ rows</span>
            </div>
          </div>

          <div class="recordpool-toolbar">
            <label class="search-box">
              <span>Buscar tema o carpeta</span>
              <input
                type="search"
                placeholder="Ejemplo: Daddy Yankee, Acapella, Tropical..."
                autocomplete="off"
                data-role="search"
              />
            </label>

            <div class="toolbar-actions">
              <button class="toggle-pill" type="button" data-role="ready-toggle">
                Solo con preview
              </button>
              <p class="results-meta" data-role="meta">Cargando catálogo...</p>
            </div>
          </div>

          <div class="category-strip" data-role="categories"></div>
          <div class="track-results" data-role="results"></div>

          <div class="recordpool-footer">
            <button class="load-more" type="button" data-role="load-more" hidden>
              Cargar más
            </button>
          </div>
        </div>
      </section>
    </Fragment>

    <Fragment slot="sidebar">
      <section class="side-card" aria-labelledby="status-title">
        <p class="side-kicker">Pulse</p>
        <h2 id="status-title">Más producto premium, menos placeholder</h2>
        <p>
          La base técnica ya estaba bien orientada. Ahora la presentación también: más contraste,
          mejores jerarquías y un ritmo visual que ayuda a percibir valor.
        </p>

        <div class="facts" aria-label="Estado del recordpool">
          <span class="fact-chip">{stats.tracks} canciones</span>
          <span class="fact-chip">{stats.folders} carpetas</span>
          <span class="fact-chip">{previewTracks} previews listos</span>
          <span class="fact-chip">{previewSeconds / 60} min por preview</span>
          {generatedAt && <span class="fact-chip">Actualizado {generatedAt}</span>}
        </div>
      </section>

      <section class="side-card" aria-labelledby="notes-title">
        <p class="side-kicker">Operativa</p>
        <h2 id="notes-title">Reglas para que la sección funcione de verdad</h2>
        <div class="side-notes">
          <div class="note-card">
            <strong>UX de recordpool</strong>
            <span>Filtrado rápido, lectura compacta y reproductor integrado en cada fila.</span>
          </div>
          <div class="note-card">
            <strong>Preview protegido</strong>
            <span>60 segundos comprimidos para enseñar el vibe sin regalar el archivo entero.</span>
          </div>
          <div class="note-card">
            <strong>Fuente intacta</strong>
            <span>Drive mantiene el orden y la web controla la experiencia de escucha.</span>
          </div>
        </div>

        <div class="side-stack">
          <a class="side-link side-link--primary" href={sourceUrl} target="_blank" rel="noopener noreferrer">
            Abrir en Google Drive ↗
          </a>
          <a class="side-link" href="/media-links/library.json">Ver JSON del catálogo ↗</a>
          <a class="side-link" href="/booking/">Ir a booking ↗</a>
        </div>
      </section>
    </Fragment>

    <Footer slot="footer" />
  </InnerPage>

  <script is:inline>
    (() => {
      const app = document.getElementById("recordpool-app");
      if (!app) return;

      const endpoint = app.getAttribute("data-endpoint");
      const searchInput = app.querySelector('[data-role="search"]');
      const metaNode = app.querySelector('[data-role="meta"]');
      const categoriesNode = app.querySelector('[data-role="categories"]');
      const resultsNode = app.querySelector('[data-role="results"]');
      const loadMoreButton = app.querySelector('[data-role="load-more"]');
      const readyToggle = app.querySelector('[data-role="ready-toggle"]');

      const state = {
        query: "",
        category: "all",
        onlyReady: false,
        limit: 40,
        categories: [],
        tracks: [],
      };

      const createElement = (tag, className, text) => {
        const node = document.createElement(tag);
        if (className) node.className = className;
        if (typeof text === "string") node.textContent = text;
        return node;
      };

      const formatTrail = (track) => {
        const trail = Array.isArray(track.trail) ? [...track.trail] : [];
        const normalizedTrail = trail[0] === track.categoryName ? trail.slice(1) : trail;
        return normalizedTrail.length
          ? `${track.categoryName} / ${normalizedTrail.join(" / ")}`
          : track.categoryName;
      };

      const inferTags = (track) => {
        const haystack = [
          track.name,
          track.categoryName,
          track.folderName,
          ...(track.trail || []),
        ]
          .join(" ")
          .toLowerCase();

        const tagRules = [
          ["acapella", "Acapella"],
          ["intro", "Intro"],
          ["clean", "Clean"],
          ["dirty", "Dirty"],
          ["tool", "Tool"],
          ["remix", "Remix"],
          ["edit", "Edit"],
          ["latin", "Latin"],
          ["reggaeton", "Reggaeton"],
          ["dembow", "Dembow"],
          ["cumbia", "Cumbia"],
          ["bachata", "Bachata"],
          ["merengue", "Merengue"],
          ["house", "House"],
          ["afro", "Afro"],
        ];

        return tagRules
          .filter(([pattern]) => haystack.includes(pattern))
          .map(([, label]) => label)
          .slice(0, 3);
      };

      const collectTracks = (rootFolder) => {
        const categories = [];
        const tracks = [];

        const walkFolder = (folder, category, trail) => {
          const nextTrail = [...trail, folder.name];

          (folder.tracks || []).forEach((track) => {
            tracks.push({
              ...track,
              categoryId: category.id,
              categoryName: category.name,
              folderName: folder.name,
              trail: nextTrail,
            });
          });

          (folder.folders || []).forEach((child) => walkFolder(child, category, nextTrail));
        };

        (rootFolder.folders || []).forEach((folder) => {
          const category = {
            id: folder.id,
            name: folder.name,
            trackCount: folder.track_count || 0,
          };
          categories.push(category);
          walkFolder(folder, category, []);
        });

        (rootFolder.tracks || []).forEach((track) => {
          tracks.push({
            ...track,
            categoryId: "root",
            categoryName: "Sueltos",
            folderName: "Sueltos",
            trail: ["Sueltos"],
          });
        });

        if ((rootFolder.tracks || []).length > 0) {
          categories.unshift({
            id: "root",
            name: "Sueltos",
            trackCount: rootFolder.tracks.length,
          });
        }

        tracks.sort((a, b) => a.name.localeCompare(b.name, "es", { sensitivity: "base" }));

        return { categories, tracks };
      };

      const getFilteredTracks = () => {
        const query = state.query.trim().toLowerCase();

        return state.tracks.filter((track) => {
          if (state.category !== "all" && track.categoryId !== state.category) return false;
          if (state.onlyReady && !track.preview_ready) return false;
          if (!query) return true;

          const haystack = [
            track.name,
            track.categoryName,
            track.folderName,
            ...(track.trail || []),
          ]
            .join(" ")
            .toLowerCase();

          return haystack.includes(query);
        });
      };

      const renderCategories = () => {
        categoriesNode.innerHTML = "";

        const allButton = createElement("button", "category-pill");
        allButton.type = "button";
        allButton.textContent = `Todas (${state.tracks.length})`;
        if (state.category === "all") allButton.classList.add("is-active");
        allButton.addEventListener("click", () => {
          state.category = "all";
          state.limit = 40;
          render();
        });
        categoriesNode.appendChild(allButton);

        state.categories.forEach((category) => {
          const button = createElement("button", "category-pill");
          button.type = "button";
          button.textContent = `${category.name} (${category.trackCount})`;
          if (state.category === category.id) button.classList.add("is-active");
          button.addEventListener("click", () => {
            state.category = category.id;
            state.limit = 40;
            render();
          });
          categoriesNode.appendChild(button);
        });
      };

      const renderTrackCard = (track, index) => {
        const card = createElement("article", "track-row");

        const slot = createElement(
          "div",
          `track-row__slot${track.preview_ready ? " is-ready" : " is-pending"}`,
          String(index + 1).padStart(2, "0")
        );

        const copy = createElement("div", "track-row__copy");
        const badges = createElement("div", "track-row__badges");
        const stateBadge = createElement(
          "span",
          `track-state${track.preview_ready ? " is-ready" : " is-pending"}`,
          track.preview_ready ? "Preview ready" : "Pending"
        );
        badges.appendChild(stateBadge);

        inferTags(track).forEach((tag) => {
          badges.appendChild(createElement("span", "track-tag", tag));
        });

        const title = createElement("strong", "track-row__title", track.name);
        const path = createElement("span", "track-row__path", formatTrail(track));
        const meta = createElement(
          "span",
          "track-row__meta",
          [track.size_label, track.modified_label].filter(Boolean).join(" · ")
        );
        copy.append(badges, title, path, meta);

        const playerWrap = createElement("div", "track-row__player");
        playerWrap.appendChild(createElement("span", "player-label", "Escucha previa"));

        if (track.preview_ready && track.preview_url) {
          const audio = createElement("audio", "track-audio");
          audio.controls = true;
          audio.preload = "none";
          audio.setAttribute("controlslist", "nodownload noplaybackrate");

          const source = document.createElement("source");
          source.src = track.preview_url;
          source.type = "audio/mpeg";
          audio.appendChild(source);
          playerWrap.appendChild(audio);
        } else {
          const pending = createElement(
            "div",
            "track-audio track-audio--pending",
            "Preview pendiente"
          );
          playerWrap.appendChild(pending);
        }

        const actions = createElement("div", "track-row__actions");
        const badge = createElement("span", "preview-badge", "Preview 1 min");
        const link = createElement("a", "track-link", "Abrir en Drive ↗");
        link.href = track.url;
        link.target = "_blank";
        link.rel = "noopener noreferrer";
        actions.append(badge, link);

        card.append(slot, copy, playerWrap, actions);
        return card;
      };

      const renderResults = (filteredTracks) => {
        resultsNode.innerHTML = "";

        if (filteredTracks.length === 0) {
          resultsNode.appendChild(
            createElement("div", "empty-state", "No hay resultados para este filtro.")
          );
          return;
        }

        const visibleTracks = filteredTracks.slice(0, state.limit);
        const fragment = document.createDocumentFragment();

        visibleTracks.forEach((track, index) => {
          fragment.appendChild(renderTrackCard(track, index));
        });

        resultsNode.appendChild(fragment);
        loadMoreButton.hidden = visibleTracks.length >= filteredTracks.length;
      };

      const render = () => {
        const filteredTracks = getFilteredTracks();
        renderCategories();
        renderResults(filteredTracks);

        metaNode.textContent = `${filteredTracks.length} resultados · ${state.onlyReady ? "solo con preview" : "todo el catálogo"}`;
        readyToggle.classList.toggle("is-active", state.onlyReady);
      };

      const boot = async () => {
        try {
          const response = await fetch(endpoint, { cache: "no-store" });
          if (!response.ok) throw new Error("No se pudo cargar el catálogo.");

          const payload = await response.json();
          const normalized = collectTracks(payload.library);
          state.categories = normalized.categories;
          state.tracks = normalized.tracks;

          render();
        } catch (error) {
          resultsNode.innerHTML = "";
          resultsNode.appendChild(
            createElement(
              "div",
              "empty-state",
              "No se pudo cargar el catálogo ahora mismo. Prueba a recargar la página."
            )
          );
          metaNode.textContent = "Error al cargar el catálogo";
        }
      };

      searchInput.addEventListener("input", (event) => {
        state.query = event.currentTarget.value;
        state.limit = 40;
        render();
      });

      readyToggle.addEventListener("click", () => {
        state.onlyReady = !state.onlyReady;
        state.limit = 40;
        render();
      });

      loadMoreButton.addEventListener("click", () => {
        state.limit += 40;
        render();
      });

      boot();
    })();
  </script>

  <style>
    .chip-row--ticker,
    .hero-actions,
    .stage-grid,
    .stage-dashboard,
    .crate-stack,
    .facts,
    .side-notes,
    .side-stack,
    .editorial-grid,
    .recordpool-shell,
    .catalog-topline,
    .recordpool-toolbar,
    .track-results,
    .recordpool-footer,
    .crate-grid,
    .program-list,
    .utility-list {
      display: grid;
      gap: 0.9rem;
    }

    .stage,
    .feature-card,
    .stage-stat,
    .stage-panel,
    .note-card,
    .empty-state,
    .track-row {
      border: 1px solid rgba(167, 231, 255, 0.1);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.04),
        0 24px 60px rgba(0, 0, 0, 0.2);
    }

    .stage {
      position: relative;
      overflow: hidden;
      padding: 1.2rem;
      background:
        linear-gradient(135deg, rgba(8, 14, 30, 0.96), rgba(5, 9, 22, 0.98)),
        rgba(5, 9, 22, 0.98);
    }

    .stage::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 12% 18%, rgba(234, 108, 63, 0.28), transparent 32%),
        radial-gradient(circle at 82% 16%, rgba(82, 232, 255, 0.22), transparent 28%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent 42%);
    }

    .stage-grid,
    .editorial-grid {
      position: relative;
      z-index: 1;
    }

    .chip-row--ticker {
      grid-template-columns: repeat(auto-fit, minmax(120px, max-content));
      margin-bottom: 1rem;
      position: relative;
      z-index: 1;
    }

    .chip-row--ticker .chip {
      border-color: rgba(82, 232, 255, 0.14);
      background: rgba(8, 14, 30, 0.72);
      color: #effaff;
    }

    .stage-copy h2 {
      margin: 0.35rem 0 0;
      max-width: 13ch;
      font-size: clamp(2rem, 5vw, 3.1rem);
      line-height: 0.96;
      letter-spacing: -0.05em;
    }

    .stage-copy .section-copy {
      margin-top: 0.9rem;
      max-width: 54ch;
      font-size: 0.98rem;
      color: rgba(231, 242, 255, 0.84);
    }

    .stage-stat,
    .stage-panel,
    .feature-card,
    .note-card,
    .track-row,
    .empty-state {
      padding: 1rem;
      border-radius: 22px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
        rgba(6, 10, 24, 0.8);
    }

    .stage-stat {
      background:
        linear-gradient(145deg, rgba(234, 108, 63, 0.2), rgba(82, 232, 255, 0.1)),
        rgba(8, 12, 26, 0.96);
    }

    .stage-stat__label {
      display: inline-flex;
      width: fit-content;
      min-height: 30px;
      align-items: center;
      padding: 0.35rem 0.7rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      color: #f2fbff;
      font-size: 0.7rem;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .stage-stat strong {
      display: block;
      margin-top: 0.8rem;
      font-size: clamp(2.5rem, 7vw, 4.1rem);
      line-height: 0.92;
      letter-spacing: -0.07em;
    }

    .stage-stat__caption {
      display: block;
      margin-top: 0.25rem;
      color: #effbff;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .stage-stat p {
      margin: 0.6rem 0 0;
      color: rgba(227, 240, 255, 0.76);
      font-size: 0.86rem;
      line-height: 1.55;
    }

