{
  "name": "marquesedition-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro build",
    "build:site": "astro build && python3 scripts/publish_dist.py",
    "preview": "astro preview --host 0.0.0.0",
    "refresh:events": "python3 scripts/update_events.py",
    "refresh:reels": "python3 scripts/update_reels.py",
    "refresh:streams": "python3 scripts/update_streams.py",
    "refresh:content": "python3 scripts/update_events.py && python3 scripts/update_reels.py && python3 scripts/update_streams.py",
    "import:events": "python3 scripts/import_bandsintown_events.py"
  },
  "dependencies": {
    "astro": "^6.0.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "typescript": "^5.9.3"
  }
}
